<div class="max-w-2xl mx-auto px-6 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-serif mb-2" style="font-weight: 700; color: #3D2E1F;">Book with <%= @pro_profile.business_name %></h1>
    <p style="color: rgba(61, 46, 31, 0.6);"><%= @pro_profile.location %></p>
  </div>

  <%= form_with model: @booking, url: pro_profile_bookings_path(@pro_profile), class: "space-y-6" do |f| %>
    <% if @booking.errors.any? %>
      <div class="rounded-2xl border-2 p-4" style="background-color: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2);">
        <% @booking.errors.full_messages.each do |message| %>
          <p class="text-sm" style="color: rgb(153, 27, 27);"><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <!-- Service Selection -->
    <div class="border-2 rounded-2xl p-6" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
      <h2 class="text-lg font-semibold mb-4" style="color: #3D2E1F;">1. Select a Service</h2>
      <% if @services.any? %>
        <div class="space-y-3">
          <% @services.each do |service| %>
            <label class="flex items-center justify-between p-4 border-2 rounded-xl cursor-pointer transition-all hover:border-amber-700" style="border-color: rgba(139, 111, 71, 0.15);">
              <div class="flex items-center gap-3">
                <%= f.radio_button :service_id, service.id, class: "w-5 h-5", style: "accent-color: #8B6F47;" %>
                <div>
                  <p class="font-semibold" style="color: #3D2E1F;"><%= service.name %></p>
                  <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= service.duration %> • <%= service.description&.truncate(60) %></p>
                </div>
              </div>
              <div class="text-right">
                <p class="font-semibold" style="color: #8B6F47;">€<%= service.price %></p>
              </div>
            </label>
          <% end %>
        </div>
      <% else %>
        <p style="color: rgba(61, 46, 31, 0.6);">This pro hasn't listed any services yet.</p>
      <% end %>
    </div>

    <!-- Pet Selection -->
    <div class="border-2 rounded-2xl p-6" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
      <h2 class="text-lg font-semibold mb-4" style="color: #3D2E1F;">2. Select Your Pet</h2>
      <% if @pets.any? %>
        <div class="space-y-3">
          <% @pets.each do |pet| %>
            <label class="flex items-center gap-3 p-4 border-2 rounded-xl cursor-pointer transition-all hover:border-amber-700" style="border-color: rgba(139, 111, 71, 0.15);">
              <%= f.radio_button :pet_id, pet.id, class: "w-5 h-5", style: "accent-color: #8B6F47;" %>
              <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #E8DFD3;">
                <span class="text-lg">🐕</span>
              </div>
              <div>
                <p class="font-semibold" style="color: #3D2E1F;"><%= pet.name %></p>
                <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= pet.breed.presence || pet.species.humanize %> • <%= pet.size_label %></p>
              </div>
            </label>
          <% end %>
        </div>
        <p class="mt-3 text-sm">
          <%= link_to "+ Add another pet", new_pet_path, style: "color: #8B6F47;" %>
        </p>
      <% else %>
        <p class="mb-4" style="color: rgba(61, 46, 31, 0.6);">You need to add a pet first.</p>
        <%= link_to "Add Your Pet", new_pet_path, class: "inline-block px-4 py-2 rounded-xl", style: "background-color: #8B6F47; color: #FAF7F2;" %>
      <% end %>
    </div>

    <!-- Date & Time -->
    <div class="border-2 rounded-2xl p-6" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
      <h2 class="text-lg font-semibold mb-4" style="color: #3D2E1F;">3. Choose Date & Time</h2>
      
      <% if @availabilities.any? %>
        <div class="mb-4 p-4 rounded-xl" style="background-color: rgba(139, 111, 71, 0.05);">
          <p class="text-sm font-semibold mb-2" style="color: #3D2E1F;"><%= @pro_profile.business_name %>'s availability:</p>
          <div class="text-sm" style="color: rgba(61, 46, 31, 0.7);">
            <% Availability::DAYS.each do |day_num, day_name| %>
              <% slots = @availabilities.select { |a| a.day_of_week == day_num } %>
              <% if slots.any? %>
                <span class="inline-block mr-3"><strong><%= day_name[0..2] %>:</strong> <%= slots.map(&:time_range).join(", ") %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-2" style="color: #3D2E1F;">Date & Start Time</label>
          <%= f.datetime_local_field :start_time,
              required: true,
              min: Time.current.strftime("%Y-%m-%dT%H:%M"),
              class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2" style="color: #3D2E1F;">End Time</label>
          <%= f.datetime_local_field :end_time,
              required: true,
              class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
      </div>
    </div>

    <!-- Notes -->
    <div class="border-2 rounded-2xl p-6" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
      <h2 class="text-lg font-semibold mb-4" style="color: #3D2E1F;">4. Special Instructions (Optional)</h2>
      <%= f.text_area :notes,
          rows: 3,
          placeholder: "Any special requests or information the pro should know...",
          class: "w-full px-4 py-3 border-2 rounded-xl focus:outline-none focus:ring-2 resize-none",
          style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
    </div>

    <!-- Submit -->
    <div class="flex items-center gap-4">
      <%= f.submit "Request Booking", 
          class: "px-8 py-4 rounded-2xl font-bold text-lg cursor-pointer transition-all hover:shadow-lg",
          style: "background-color: #8B6F47; color: #FAF7F2;",
          disabled: @pets.empty? || @services.empty? %>
      <%= link_to "Cancel", pro_profile_path(@pro_profile), class: "font-medium", style: "color: rgba(61, 46, 31, 0.6);" %>
    </div>

    <p class="text-sm text-center" style="color: rgba(61, 46, 31, 0.5);">
      Your booking request will be sent to <%= @pro_profile.business_name %> for confirmation.
    </p>
  <% end %>
</div>
