<div class="mx-auto px-4 py-8" style="max-width: 520px; font-family: 'Nunito', sans-serif;">
  
  <%= link_to booking_path(@booking), class: "inline-flex items-center gap-2 text-sm font-medium mb-6", style: "color: #8B6F47;" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
    Back
  <% end %>

  <h1 class="text-2xl font-bold mb-2" style="color: #3D2E1F;">Leave a Review</h1>
  <p class="text-sm mb-6" style="color: #A89F91;">How was your experience with <%= @booking.pro_profile.business_name %>?</p>

  <%= form_with model: [@booking, @review], local: true, data: { controller: "star-rating photo-preview" } do |f| %>
    
    <% if @review.errors.any? %>
      <div class="mb-4 p-3" style="background: #FFEBEE; color: #C62828;">
        <% @review.errors.full_messages.each do |msg| %>
          <p class="text-sm"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <!-- Star Rating -->
    <div class="mb-6">
      <label class="block text-sm font-bold mb-3" style="color: #3D2E1F;">Rating</label>
      <div class="flex gap-2" data-star-rating-target="stars">
        <% (1..5).each do |n| %>
          <label class="cursor-pointer">
            <%= f.radio_button :rating, n, class: "hidden", data: { action: "star-rating#select", star_rating_target: "input" } %>
            <span class="text-3xl transition-colors" data-star-rating-target="star" data-value="<%= n %>" style="color: #E8E0D5;">★</span>
          </label>
        <% end %>
      </div>
    </div>

    <!-- Review Text -->
    <div class="mb-6">
      <label class="block text-sm font-bold mb-2" style="color: #3D2E1F;">Your Review <span style="color: #A89F91; font-weight: normal;">(optional)</span></label>
      <%= f.text_area :content, rows: 4, placeholder: "Tell others about your experience...", class: "w-full px-4 py-3 text-sm", style: "border: 1px solid #E8E0D5; background: white; color: #3D2E1F; resize: none;" %>
    </div>

    <!-- Photo Upload -->
    <div class="mb-6">
      <label class="block text-sm font-bold mb-2" style="color: #3D2E1F;">Add Photos <span style="color: #A89F91; font-weight: normal;">(optional)</span></label>
      <div class="flex flex-wrap gap-3" data-photo-preview-target="container">
        <label class="w-20 h-20 flex items-center justify-center cursor-pointer" style="border: 2px dashed #E8E0D5;">
          <%= f.file_field :photos, multiple: true, accept: "image/*", class: "hidden", data: { action: "photo-preview#preview", photo_preview_target: "input" } %>
          <span class="text-2xl" style="color: #A89F91;">+</span>
        </label>
      </div>
      <p class="text-xs mt-2" style="color: #A89F91;">Share photos from <%= @booking.pet&.name %>'s visit</p>
    </div>

    <!-- Submit -->
    <%= f.submit "Submit Review", class: "w-full py-3 text-sm font-bold cursor-pointer", style: "background: #8B6F47; color: white;" %>
  <% end %>
</div>
