<div class="max-w-2xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8 text-center">
    <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl text-white mb-4" style="background: linear-gradient(135deg, #F59E0B, #EC4899);">
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold" style="color: hsl(20, 14%, 16%);">Leave a Review</h1>
    <p class="mt-2" style="color: hsl(25, 10%, 45%);">How was your experience with <%= @booking.pro_profile.business_name %>?</p>
  </div>

  <%= form_with model: @review, url: booking_reviews_path(@booking), class: "space-y-6" do |f| %>
    <% if @review.errors.any? %>
      <div class="rounded-xl border p-4" style="background-color: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2);">
        <% @review.errors.full_messages.each do |message| %>
          <p class="text-sm" style="color: rgb(153, 27, 27);"><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div class="rounded-xl border p-6 space-y-6" style="background-color: white; border-color: hsl(35, 20%, 88%);">
      <div>
        <label class="block text-sm font-medium mb-3" style="color: hsl(25, 10%, 45%);">Rating</label>
        <div class="flex gap-2">
          <% (1..5).each do |star| %>
            <label class="cursor-pointer group">
              <%= f.radio_button :rating, star, class: "sr-only peer", required: true %>
              <span class="text-4xl transition peer-checked:scale-110" style="color: hsl(35, 20%, 88%);" 
                    onmouseover="this.style.color='#F59E0B'" 
                    onmouseout="if(!this.previousElementSibling.checked) this.style.color='hsl(35, 20%, 88%)'"
                    onclick="this.style.color='#F59E0B'; document.querySelectorAll('.star-rating').forEach((s,i) => s.style.color = i < <%= star %> ? '#F59E0B' : 'hsl(35, 20%, 88%)')">★</span>
            </label>
          <% end %>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" style="color: hsl(25, 10%, 45%);">Your Review</label>
        <%= f.text_area :comment,
            rows: 4,
            placeholder: "Tell others about your experience...",
            class: "w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2 resize-none",
            style: "border-color: hsl(35, 20%, 88%);" %>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <%= f.submit "Submit Review", 
          class: "rounded-xl px-6 py-3 text-base font-bold text-white shadow-md transition cursor-pointer",
          style: "background-color: #EC4899; box-shadow: 0 4px 14px rgba(236, 72, 153, 0.2);" %>
      <%= link_to "Cancel", dashboard_path, class: "font-medium", style: "color: hsl(25, 10%, 45%);" %>
    </div>
  <% end %>
</div>
