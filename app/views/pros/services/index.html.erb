<div class="max-w-4xl mx-auto px-6 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-heading mb-2" style="font-weight: 700; color: #3D2E1F;">Services & Pricing</h1>
      <p style="color: rgba(61, 46, 31, 0.6);">Manage the services you offer to clients</p>
    </div>
    <%= link_to new_pros_service_path, class: "inline-flex items-center gap-2 px-5 py-3 rounded-xl font-semibold", style: "background-color: #8B6F47; color: #FAF7F2;" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add Service
    <% end %>
  </div>

  <% if @services.any? %>
    <div class="space-y-4">
      <% @services.each do |service| %>
        <div class="border-2 rounded-2xl p-6 flex gap-6" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
          <!-- Photo -->
          <div class="flex-shrink-0 w-24 h-24 rounded-xl overflow-hidden" style="background-color: rgba(139, 111, 71, 0.1);">
            <% if service.photo.attached? %>
              <%= image_tag service.photo, class: "w-full h-full object-cover" %>
            <% elsif service.photo_url.present? %>
              <%= image_tag service.photo_url, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-8 h-8" fill="none" stroke="rgba(139, 111, 71, 0.4)" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            <% end %>
          </div>

          <!-- Details -->
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-lg font-semibold mb-1" style="color: #3D2E1F;"><%= service.name %></h3>
                <p class="text-2xl font-bold" style="color: #8B6F47;">
                  <%= service.formatted_price %><span class="text-sm font-normal" style="color: rgba(61, 46, 31, 0.5);"><%= service.payment_type_label %></span>
                </p>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to edit_pros_service_path(service), class: "p-2 rounded-lg hover:bg-gray-100 transition", title: "Edit" do %>
                  <svg class="w-5 h-5" fill="none" stroke="#8B6F47" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                  </svg>
                <% end %>
                <%= button_to pros_service_path(service), method: :delete, data: { turbo_confirm: "Remove this service?" }, class: "p-2 rounded-lg hover:bg-red-50 transition", title: "Delete" do %>
                  <svg class="w-5 h-5" fill="none" stroke="#ef4444" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                <% end %>
              </div>
            </div>
            <% if service.description.present? %>
              <p class="mt-2 text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= service.description %></p>
            <% end %>
            <% if service.duration.present? %>
              <p class="mt-2 text-sm" style="color: rgba(61, 46, 31, 0.5);">
                <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <%= service.duration %>
              </p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 border-2 border-dashed rounded-2xl" style="border-color: rgba(139, 111, 71, 0.3);">
      <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="rgba(139, 111, 71, 0.4)" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
      </svg>
      <p class="text-lg mb-2" style="color: rgba(61, 46, 31, 0.6);">No services yet</p>
      <p class="text-sm mb-6" style="color: rgba(61, 46, 31, 0.4);">Add services to let clients know what you offer</p>
      <%= link_to new_pros_service_path, class: "inline-flex items-center gap-2 px-5 py-3 rounded-xl font-semibold", style: "background-color: #8B6F47; color: #FAF7F2;" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Your First Service
      <% end %>
    </div>
  <% end %>

  <!-- Back to Dashboard -->
  <div class="mt-8 pt-8 border-t" style="border-color: rgba(139, 111, 71, 0.15);">
    <%= link_to "← Back to Dashboard", dashboard_path, style: "color: #8B6F47;" %>
  </div>
</div>
