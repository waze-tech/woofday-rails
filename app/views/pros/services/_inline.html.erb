<%= turbo_frame_tag "pro_panel" do %><div style="min-height: 360px;" data-controller="service-inline">
  <div class="px-6 py-4 flex items-center justify-between" style="border-bottom: 1px solid rgba(139, 111, 71, 0.06); background: linear-gradient(to right, rgba(139, 111, 71, 0.03), transparent);">
    <div>
      <h2 class="text-lg font-bold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Services & Pricing</h2>
      <p class="text-sm font-medium" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Manage what you offer</p>
    </div>
    <button type="button" data-action="click->service-inline#showForm" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 hover:translate-y-[-1px]" style="background: linear-gradient(135deg, #8B6F47, #A68B5B); color: white; box-shadow: 0 2px 8px rgba(139, 111, 71, 0.25); font-family: 'Nunito', sans-serif;">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      Add Service
    </button>
  </div>
  
  <div class="divide-y" style="border-color: rgba(139, 111, 71, 0.05);">
    <!-- Add Service Form (hidden by default) -->
    <div data-service-inline-target="form" class="hidden p-6" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.04), rgba(139, 111, 71, 0.01)); border-bottom: 1px solid rgba(139, 111, 71, 0.08);">
      <%= form_with url: pros_services_path(inline: true), scope: :service, multipart: true, class: "space-y-5", data: { turbo_frame: "pro_panel", controller: "photo-preview" } do |f| %>
        
        <!-- Photo Upload -->
        <div class="flex items-start gap-4">
          <div data-photo-preview-target="preview" class="w-20 h-20 rounded-xl flex items-center justify-center flex-shrink-0 overflow-hidden" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.1), rgba(139, 111, 71, 0.05)); border: 2px dashed rgba(139, 111, 71, 0.2);">
            <svg class="w-8 h-8" fill="none" stroke="rgba(139, 111, 71, 0.4)" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          </div>
          <div class="flex-1">
            <label class="block text-xs font-bold uppercase tracking-wide mb-2" style="color: rgba(61, 46, 31, 0.5);">Service Photo</label>
            <%= f.file_field :photo, accept: "image/*", data: { action: "change->photo-preview#preview", photo_preview_target: "input" }, class: "hidden", id: "service_photo_input" %>
            <label for="service_photo_input" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold cursor-pointer transition-all hover:bg-amber-50" style="background: rgba(139, 111, 71, 0.08); color: #8B6F47;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
              Upload Photo
            </label>
            <p class="text-xs mt-1.5" style="color: rgba(61, 46, 31, 0.4);">JPG, PNG up to 5MB</p>
          </div>
        </div>

        <!-- Service Name -->
        <div>
          <label class="block text-xs font-bold uppercase tracking-wide mb-2" style="color: rgba(61, 46, 31, 0.5);">Service Name</label>
          <%= f.text_field :name, placeholder: "e.g. Full Groom, Dog Walking", required: true, class: "w-full px-4 py-3 text-sm font-semibold rounded-xl transition-all focus:outline-none focus:ring-2", style: "border: 1px solid rgba(139, 111, 71, 0.15); background: white; color: #3D2E1F; font-family: 'Nunito', sans-serif; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.06); --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
        </div>

        <!-- Price Row -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wide mb-2" style="color: rgba(61, 46, 31, 0.5);">Price</label>
            <div class="flex">
              <%= f.select :currency, Service::CURRENCIES.map { |c| [c[:symbol], c[:code]] }, {}, class: "px-3 py-3 text-sm font-bold rounded-l-xl border-r-0", style: "border: 1px solid rgba(139, 111, 71, 0.15); background: rgba(139, 111, 71, 0.05); color: #8B6F47; font-family: 'Nunito', sans-serif;" %>
              <%= f.number_field :price, placeholder: "0.00", step: "0.01", min: 0, required: true, class: "flex-1 px-4 py-3 text-sm font-semibold rounded-r-xl transition-all focus:outline-none focus:ring-2", style: "border: 1px solid rgba(139, 111, 71, 0.15); background: white; color: #3D2E1F; font-family: 'Nunito', sans-serif; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.06); --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wide mb-2" style="color: rgba(61, 46, 31, 0.5);">Pricing Type</label>
            <%= f.select :payment_type, [["Per session", "per_session"], ["Per hour", "per_hour"], ["Per day", "per_day"]], {}, class: "w-full px-4 py-3 text-sm font-semibold rounded-xl transition-all focus:outline-none focus:ring-2", style: "border: 1px solid rgba(139, 111, 71, 0.15); background: white; color: #3D2E1F; font-family: 'Nunito', sans-serif; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.06); --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
          </div>
        </div>

        <!-- Duration -->
        <div>
          <label class="block text-xs font-bold uppercase tracking-wide mb-2" style="color: rgba(61, 46, 31, 0.5);">Duration <span class="font-normal">(optional)</span></label>
          <%= f.select :duration, [["Select duration", ""]] + Service::DURATIONS.map { |d| [d, d] }, {}, class: "w-full px-4 py-3 text-sm font-semibold rounded-xl transition-all focus:outline-none focus:ring-2", style: "border: 1px solid rgba(139, 111, 71, 0.15); background: white; color: #3D2E1F; font-family: 'Nunito', sans-serif; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.06); --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
        </div>

        <!-- Description -->
        <div>
          <label class="block text-xs font-bold uppercase tracking-wide mb-2" style="color: rgba(61, 46, 31, 0.5);">Description <span class="font-normal">(optional)</span></label>
          <%= f.text_area :description, placeholder: "Describe what's included in this service...", rows: 3, class: "w-full px-4 py-3 text-sm font-medium rounded-xl resize-none transition-all focus:outline-none focus:ring-2", style: "border: 1px solid rgba(139, 111, 71, 0.15); background: white; color: #3D2E1F; font-family: 'Nunito', sans-serif; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.06); --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
        </div>

        <!-- Actions -->
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" data-action="click->service-inline#hideForm" class="px-5 py-2.5 text-sm font-bold rounded-xl transition-colors hover:bg-gray-100" style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;">Cancel</button>
          <%= f.submit "Save Service", class: "px-6 py-2.5 text-sm font-bold rounded-xl cursor-pointer transition-all duration-200 hover:translate-y-[-1px]", style: "background: linear-gradient(135deg, #8B6F47, #A68B5B); color: white; box-shadow: 0 2px 8px rgba(139, 111, 71, 0.3); font-family: 'Nunito', sans-serif;" %>
        </div>
      <% end %>
    </div>

    <!-- Services List -->
    <% if @services.any? %>
      <% @services.each do |service| %>
        <div class="p-4 flex items-center gap-4 transition-all duration-200 hover:bg-gray-50/50 group">
          <div class="flex-shrink-0 w-14 h-14 rounded-xl overflow-hidden transition-transform duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.12), rgba(139, 111, 71, 0.06)); box-shadow: 0 2px 6px rgba(139, 111, 71, 0.1);">
            <% if service.photo.attached? %>
              <%= image_tag service.photo, class: "w-full h-full object-cover" %>
            <% elsif service.photo_url.present? %>
              <%= image_tag service.photo_url, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-sm" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;"><%= service.name %></p>
            <p class="text-lg font-extrabold" style="color: #8B6F47; font-family: 'Nunito', sans-serif;"><%= service.formatted_price %><span class="text-xs font-medium ml-1" style="color: rgba(61, 46, 31, 0.4);"><%= service.payment_type_label %></span></p>
          </div>
          <div class="flex items-center gap-1 opacity-60 group-hover:opacity-100 transition-opacity">
            <%= link_to edit_pros_service_path(service, inline: true), data: { turbo_frame: "pro_panel" }, class: "p-2.5 rounded-xl transition-colors hover:bg-gray-100" do %>
              <svg class="w-4 h-4" fill="none" stroke="rgba(61, 46, 31, 0.5)" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
            <% end %>
            <%= button_to pros_service_path(service, inline: true), method: :delete, data: { turbo_confirm: "Remove this service?", turbo_frame: "pro_panel" }, class: "p-2.5 rounded-xl transition-colors hover:bg-red-50" do %>
              <svg class="w-4 h-4" fill="none" stroke="#ef4444" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="p-10 text-center">
        <div class="mx-auto mb-4 w-16 h-16 rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.1), rgba(139, 111, 71, 0.05));">
          <svg class="w-8 h-8" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>
        </div>
        <p class="font-bold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">No services yet</p>
        <p class="text-sm mt-1 font-medium" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Add your first service to get started</p>
      </div>
    <% end %>
  </div>
</div><% end %>
