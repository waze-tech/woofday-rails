<%= turbo_frame_tag "pro_panel" do %>
  <div class="px-5 py-4 border-b flex items-center justify-between" style="border-color: rgba(139, 111, 71, 0.1);">
    <h2 class="text-lg font-semibold" style="color: #3D2E1F;">Edit Service</h2>
    <%= link_to pros_services_path(inline: true), data: { turbo_frame: "pro_panel" }, class: "text-sm", style: "color: #8B6F47;" do %>
      ← Back
    <% end %>
  </div>
  
  <div class="p-5">
    <%= form_with model: [:pros, @service], url: pros_service_path(@service, inline: true), class: "space-y-4", data: { turbo_frame: "pro_panel" }, multipart: true do |f| %>
      <% if @service.errors.any? %>
        <div class="rounded-lg p-3 text-sm" style="background-color: rgba(239, 68, 68, 0.1); color: rgb(153, 27, 27);">
          <% @service.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <!-- Photo -->
      <div>
        <label class="block text-sm font-medium mb-2" style="color: #3D2E1F;">Photo</label>
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-xl overflow-hidden" style="background-color: rgba(139, 111, 71, 0.1);">
            <% if @service.photo.attached? %>
              <%= image_tag @service.photo, class: "w-full h-full object-cover" %>
            <% elsif @service.photo_url.present? %>
              <%= image_tag @service.photo_url, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="rgba(139, 111, 71, 0.4)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
            <% end %>
          </div>
          <%= f.file_field :photo, accept: "image/*", class: "flex-1 text-sm", style: "color: rgba(61, 46, 31, 0.6);" %>
        </div>
        <div class="mt-2">
          <%= f.url_field :photo_url, placeholder: "Or paste image URL", class: "w-full px-3 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Name</label>
          <%= f.text_field :name, required: true, class: "w-full px-3 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
        </div>
        <div class="flex gap-2">
          <div class="flex-1">
            <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Price</label>
            <%= f.number_field :price, step: "0.01", min: 0, required: true, class: "w-full px-3 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
          </div>
          <div class="w-20">
            <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">&nbsp;</label>
            <%= f.select :currency, Service::CURRENCIES.map { |c| [c[:symbol], c[:code]] }, {}, class: "w-full px-2 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
          </div>
        </div>
      </div>
      
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Payment Type</label>
          <%= f.select :payment_type, [["Per session", "per_session"], ["Per hour", "per_hour"], ["Per day", "per_day"]], {}, class: "w-full px-3 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Duration</label>
          <%= f.select :duration, [["None", ""]] + Service::DURATIONS.map { |d| [d, d] }, {}, class: "w-full px-3 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Description</label>
        <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 text-sm border rounded-lg resize-none", style: "border-color: rgba(139, 111, 71, 0.2);" %>
      </div>
      
      <div class="flex justify-end gap-2 pt-2">
        <%= link_to "Cancel", pros_services_path(inline: true), data: { turbo_frame: "pro_panel" }, class: "px-4 py-2 text-sm rounded-lg", style: "color: rgba(61, 46, 31, 0.6);" %>
        <%= f.submit "Save", class: "px-4 py-2 text-sm rounded-lg cursor-pointer", style: "background-color: #8B6F47; color: white;" %>
      </div>
    <% end %>
  </div>
<% end %>
