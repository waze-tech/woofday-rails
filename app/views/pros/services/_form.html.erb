<%= form_with model: [:pros, service], class: "space-y-6", multipart: true do |f| %>
  <% if service.errors.any? %>
    <div class="rounded-xl border p-4" style="background-color: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2);">
      <% service.errors.full_messages.each do |message| %>
        <p class="text-sm" style="color: rgb(153, 27, 27);"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <!-- Photo Upload -->
  <div class="space-y-2">
    <%= f.label :photo, "Service Photo", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
    <div class="flex items-center gap-4">
      <div class="w-24 h-24 rounded-xl overflow-hidden flex-shrink-0" style="background-color: rgba(139, 111, 71, 0.1);">
        <% if service.photo.attached? %>
          <%= image_tag service.photo, class: "w-full h-full object-cover" %>
        <% elsif service.photo_url.present? %>
          <%= image_tag service.photo_url, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center">
            <svg class="w-8 h-8" fill="none" stroke="rgba(139, 111, 71, 0.4)" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
        <% end %>
      </div>
      <div class="flex-1">
        <%= f.file_field :photo, accept: "image/*", class: "w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:cursor-pointer", style: "color: rgba(61, 46, 31, 0.6);" %>
        <p class="text-xs mt-1" style="color: rgba(61, 46, 31, 0.4);">Or paste an image URL below</p>
      </div>
    </div>
  </div>

  <div class="space-y-2">
    <%= f.label :photo_url, "Image URL (optional)", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
    <%= f.url_field :photo_url, placeholder: "https://example.com/photo.jpg", class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
  </div>

  <div class="space-y-2">
    <%= f.label :name, "Service Name", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
    <%= f.text_field :name, required: true, placeholder: "e.g., Full Grooming Package", class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
  </div>

  <div class="space-y-2">
    <%= f.label :description, "Description (optional)", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
    <%= f.text_area :description, rows: 3, placeholder: "What's included in this service?", class: "w-full px-4 py-3 border-2 rounded-xl focus:outline-none focus:ring-2 resize-none", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
  </div>

  <div class="grid md:grid-cols-3 gap-4">
    <div class="space-y-2">
      <%= f.label :price, "Price", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
      <%= f.number_field :price, step: "0.01", min: 0, required: true, placeholder: "0.00", class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
    </div>

    <div class="space-y-2">
      <%= f.label :currency, "Currency", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
      <%= f.select :currency, Service::CURRENCIES.map { |c| ["#{c[:symbol]} #{c[:code]}", c[:code]] }, {}, class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
    </div>

    <div class="space-y-2">
      <%= f.label :payment_type, "Payment Type", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
      <%= f.select :payment_type, [["Per Session", "per_session"], ["Per Hour", "per_hour"], ["Per Day", "per_day"]], {}, class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
    </div>
  </div>

  <div class="space-y-2">
    <%= f.label :duration, "Duration", class: "block text-sm font-medium", style: "color: #3D2E1F;" %>
    <%= f.select :duration, [["Select duration (optional)", ""]] + Service::DURATIONS.map { |d| [d, d] }, {}, class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
  </div>

  <div class="flex justify-end gap-4 pt-4">
    <%= link_to "Cancel", pros_services_path, class: "px-6 py-3 border-2 rounded-xl font-medium", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
    <%= f.submit service.persisted? ? "Update Service" : "Add Service", class: "px-6 py-3 rounded-xl font-semibold cursor-pointer", style: "background-color: #8B6F47; color: #FAF7F2;" %>
  </div>
<% end %>
