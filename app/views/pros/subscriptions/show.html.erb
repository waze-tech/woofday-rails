<div class="mx-auto px-4 py-8 sm:px-6 lg:px-8" style="max-width: 640px; font-family: 'Nunito', sans-serif;">
  <% if params[:success] %>
    <div class="mb-6 rounded-2xl p-5" style="background: linear-gradient(135deg, rgba(34, 197, 94, 0.1), rgba(34, 197, 94, 0.05)); border: 1px solid rgba(34, 197, 94, 0.2);">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(34, 197, 94, 0.15);">
          <svg class="w-5 h-5" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="font-bold" style="color: rgb(34, 197, 94);">You're all set!</p>
          <p class="text-sm" style="color: rgba(34, 197, 94, 0.8);">Your Pro subscription is now active.</p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-extrabold mb-2" style="color: #3D2E1F;">Your Plan</h1>
    <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Manage your woof.day subscription</p>
  </div>

  <% if @pro_profile.tier_pro? %>
    <!-- Pro Plan - Active -->
    <div class="rounded-2xl overflow-hidden" style="background: white; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 8px 24px rgba(139, 111, 71, 0.06);">
      <!-- Plan Header -->
      <div class="p-6" style="background: linear-gradient(135deg, #8B6F47 0%, #A68B5B 100%);">
        <div class="flex items-center justify-between mb-4">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide" style="background: rgba(255,255,255,0.2); color: white;">
            Current Plan
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold" style="background: rgba(34, 197, 94, 0.2); color: rgb(134, 239, 172);">
            <span class="w-1.5 h-1.5 rounded-full" style="background: rgb(34, 197, 94);"></span>
            Active
          </span>
        </div>
        <div class="flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-white">€19</span>
          <span class="text-white/70">/month</span>
        </div>
        <p class="mt-2 text-white/80 text-sm">Pet Care Pro</p>
      </div>

      <!-- Plan Details -->
      <div class="p-6">
        <% if @pro_profile.subscription_expires_at %>
          <div class="flex items-center gap-3 p-4 rounded-xl mb-6" style="background: rgba(139, 111, 71, 0.04);">
            <svg class="w-5 h-5" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
            </svg>
            <div>
              <p class="text-xs font-medium" style="color: rgba(61, 46, 31, 0.5);">Next billing date</p>
              <p class="font-semibold" style="color: #3D2E1F;"><%= @pro_profile.subscription_expires_at.strftime("%B %d, %Y") %></p>
            </div>
          </div>
        <% end %>

        <h3 class="text-sm font-bold uppercase tracking-wide mb-4" style="color: rgba(61, 46, 31, 0.4);">What's included</h3>
        
        <div class="space-y-2.5 mb-6">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Everything in Free</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Unlimited services</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Online booking system</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Calendar integration</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Verified reviews</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Social sharing tools</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Priority support</p>
          </div>
        </div>

        <%= button_to "Manage Billing", portal_pros_subscription_path, method: :post, data: { turbo: false }, class: "w-full py-3.5 rounded-xl text-sm font-bold transition-all duration-200 cursor-pointer", style: "background: #8B6F47; color: white; box-shadow: 0 2px 8px rgba(139, 111, 71, 0.25);" %>
        
        <p class="text-center mt-4 text-xs" style="color: rgba(61, 46, 31, 0.4);">
          Update payment method or cancel anytime
        </p>
      </div>
    </div>

  <% else %>
    <!-- Free Plan - Upgrade CTA -->
    <div class="rounded-2xl overflow-hidden" style="background: white; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 8px 24px rgba(139, 111, 71, 0.06);">
      <!-- Current Plan -->
      <div class="p-6" style="border-bottom: 1px solid rgba(139, 111, 71, 0.08);">
        <div class="flex items-center justify-between">
          <div>
            <span class="text-xs font-bold uppercase tracking-wide" style="color: rgba(61, 46, 31, 0.4);">Current Plan</span>
            <p class="text-xl font-extrabold mt-1" style="color: #3D2E1F;">Free</p>
          </div>
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(139, 111, 71, 0.06);">
            <svg class="w-6 h-6" fill="none" stroke="rgba(139, 111, 71, 0.4)" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Upgrade Section -->
      <div class="p-6" style="background: linear-gradient(180deg, rgba(139, 111, 71, 0.02) 0%, rgba(139, 111, 71, 0.06) 100%);">
        <div class="text-center mb-6">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.1), rgba(139, 111, 71, 0.05));">
            <svg class="w-4 h-4" fill="#8B6F47" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span class="text-sm font-bold" style="color: #8B6F47;">Recommended</span>
          </div>
          <h3 class="text-2xl font-extrabold mb-2" style="color: #3D2E1F;">Pet Care Pro</h3>
          <div class="flex items-baseline justify-center gap-1">
            <span class="text-4xl font-extrabold" style="color: #8B6F47;">€19</span>
            <span style="color: rgba(61, 46, 31, 0.5);">/month</span>
          </div>
        </div>

        <p class="text-sm mb-5" style="color: rgba(61, 46, 31, 0.6);">Everything you need to grow</p>
        
        <div class="space-y-2.5 mb-6">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Everything in Free</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Unlimited services</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Online booking system</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Calendar integration</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Verified reviews</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Social sharing tools</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#8B6F47" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <p class="font-semibold text-sm" style="color: #3D2E1F;">Priority support</p>
          </div>
        </div>

        <%= button_to "Start Pro — €19/month", pros_subscription_path, method: :post, data: { turbo: false }, class: "w-full py-4 rounded-xl text-sm font-bold transition-all duration-200 cursor-pointer", style: "background: linear-gradient(135deg, #8B6F47 0%, #A68B5B 100%); color: white; box-shadow: 0 4px 14px rgba(139, 111, 71, 0.35);" %>
        
        <p class="text-center mt-4 text-xs" style="color: rgba(61, 46, 31, 0.4);">
          Cancel anytime. No long-term commitment.
        </p>
      </div>
    </div>
  <% end %>

  <div class="mt-8 text-center">
    <%= link_to dashboard_path, class: "inline-flex items-center gap-2 text-sm font-medium transition-colors", style: "color: #8B6F47;" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Back to Dashboard
    <% end %>
  </div>
</div>
