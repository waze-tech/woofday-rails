<div class="max-w-4xl mx-auto px-6 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-serif mb-2" style="font-weight: 700; color: #3D2E1F;">Availability</h1>
    <p style="color: rgba(61, 46, 31, 0.6);">Set your weekly schedule so clients can book with you</p>
  </div>

  <!-- Add Availability Form -->
  <div class="border-2 rounded-2xl p-6 mb-8" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
    <h2 class="text-lg font-semibold mb-4" style="color: #3D2E1F;">Add Time Slot</h2>
    <%= form_with model: @availability, url: pros_availabilities_path, class: "grid md:grid-cols-4 gap-4 items-end" do |f| %>
      <div>
        <%= f.label :day_of_week, "Day", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
        <%= f.select :day_of_week, Availability::DAYS.map { |k, v| [v, k] }, {}, class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
      </div>
      <div>
        <%= f.label :start_time, "Start Time", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
        <%= f.time_field :start_time, class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
      </div>
      <div>
        <%= f.label :end_time, "End Time", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
        <%= f.time_field :end_time, class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
      </div>
      <div>
        <%= f.submit "Add", class: "w-full h-12 rounded-xl font-semibold cursor-pointer", style: "background-color: #8B6F47; color: #FAF7F2;" %>
      </div>
    <% end %>
  </div>

  <!-- Weekly Schedule -->
  <div class="border-2 rounded-2xl overflow-hidden" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
    <% Availability::DAYS.each do |day_num, day_name| %>
      <% day_slots = @availabilities.select { |a| a.day_of_week == day_num } %>
      <div class="flex items-center border-b last:border-b-0 p-4" style="border-color: rgba(139, 111, 71, 0.1);">
        <div class="w-32 font-semibold" style="color: #3D2E1F;"><%= day_name %></div>
        <div class="flex-1">
          <% if day_slots.any? %>
            <div class="flex flex-wrap gap-2">
              <% day_slots.each do |slot| %>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg" style="background-color: rgba(139, 111, 71, 0.1);">
                  <span style="color: #3D2E1F;"><%= slot.time_range %></span>
                  <%= button_to pros_availability_path(slot), method: :delete, class: "text-red-500 hover:text-red-700" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <span class="text-sm" style="color: rgba(61, 46, 31, 0.4);">Not available</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Blocked Dates Link -->
  <div class="mt-6 p-4 rounded-xl" style="background-color: rgba(139, 111, 71, 0.05);">
    <div class="flex items-center justify-between">
      <div>
        <p class="font-semibold" style="color: #3D2E1F;">Need to block specific dates?</p>
        <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Mark holidays, vacation, or sick days</p>
      </div>
      <%= link_to "Manage Blocked Dates →", pros_blocked_dates_path, class: "font-semibold", style: "color: #8B6F47;" %>
    </div>
  </div>

  <!-- Back to Dashboard -->
  <div class="mt-8 pt-8 border-t" style="border-color: rgba(139, 111, 71, 0.15);">
    <%= link_to "← Back to Dashboard", dashboard_path, style: "color: #8B6F47;" %>
  </div>
</div>
