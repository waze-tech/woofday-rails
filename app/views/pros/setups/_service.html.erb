<%= turbo_frame_tag dom_id(service) do %>
  <div class="rounded-3xl border-2 overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 group" style="background-color: white; border-color: rgba(139, 111, 71, 0.15);">
    <div class="p-7">
      <div class="flex items-start justify-between gap-3 mb-4">
        <h3 class="flex-1" style="font-size: 1.125rem; font-weight: 600; color: #3D2E1F;"><%= service.name %></h3>
        <%= button_to pros_setup_service_path(service), method: :delete, data: { turbo_confirm: "Remove this service?" }, class: "p-2 rounded-xl transition-all opacity-0 group-hover:opacity-100 hover:bg-red-50", style: "color: rgba(61, 46, 31, 0.4);" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        <% end %>
      </div>
      <div class="flex items-baseline gap-2 mb-4">
        <span class="text-3xl" style="font-family: Georgia, serif; color: #8B6F47;"><%= service.formatted_price %></span>
        <span class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= service.payment_type_label %></span>
      </div>
      <% if service.description.present? %>
        <p class="text-sm mb-4 line-clamp-2 leading-relaxed" style="color: rgba(61, 46, 31, 0.6);"><%= service.description %></p>
      <% end %>
      <% if service.duration.present? %>
        <div class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm w-fit" style="background-color: rgba(139, 111, 71, 0.1); color: rgba(61, 46, 31, 0.7);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><%= service.duration %></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
