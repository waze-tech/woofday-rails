<div class="space-y-10">
  <div class="text-center max-w-xl mx-auto">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background-color: rgba(139, 111, 71, 0.1);">
      <svg class="w-4 h-4" fill="none" stroke="#8B6F47" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
      <span class="text-sm" style="color: #8B6F47;">Your Story</span>
    </div>
    <h1 class="mb-4" style="font-family: Georgia, serif; font-size: 2rem; color: #3D2E1F;">Build Your Profile</h1>
    <p class="text-lg leading-relaxed" style="color: rgba(61, 46, 31, 0.6);">
      Share your story and let pet owners know what makes you special.
    </p>
  </div>

  <%= form_with model: @pro_profile, url: pros_setup_path, method: :patch do |f| %>
    <div class="rounded-3xl border-2 p-12 space-y-8 shadow-xl" style="background-color: white; border-color: rgba(139, 111, 71, 0.15);">
      <div class="space-y-4">
        <%= f.label :business_name, "Business Name", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
        <%= f.text_field :business_name, placeholder: "e.g., Paws & Claws Grooming", class: "w-full px-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 transition-all shadow-sm hover:shadow-md", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.2);" %>
      </div>

      <div class="space-y-4">
        <%= f.label :bio, "Bio", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
        <%= f.text_area :bio, rows: 5, placeholder: "Share your experience, specializations, and what makes your service unique...", class: "w-full px-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 resize-none transition-all leading-relaxed shadow-sm hover:shadow-md", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.2);" %>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <%= f.label :location, "Location", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
          <div class="relative group">
            <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5" fill="none" stroke="rgba(61, 46, 31, 0.4)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <%= f.text_field :location, placeholder: "City, State or ZIP", class: "w-full pl-13 pr-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 transition-all shadow-sm hover:shadow-md", style: "padding-left: 3.25rem; border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.2);" %>
          </div>
        </div>

        <div class="space-y-4">
          <%= f.label :phone, "Phone Number", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
          <div class="relative group">
            <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5" fill="none" stroke="rgba(61, 46, 31, 0.4)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <%= f.telephone_field :phone, placeholder: "(555) 123-4567", class: "w-full pl-13 pr-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 transition-all shadow-sm hover:shadow-md", style: "padding-left: 3.25rem; border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.2);" %>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <%= f.label :email, "Email Address", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
        <div class="relative group">
          <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5" fill="none" stroke="rgba(61, 46, 31, 0.4)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <%= f.email_field :email, value: @pro_profile.email || Current.user.email_address, placeholder: "your@email.com", class: "w-full pl-13 pr-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 transition-all shadow-sm hover:shadow-md", style: "padding-left: 3.25rem; border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.2);" %>
        </div>
      </div>
    </div>
    
    <!-- Specialties Section -->
    <div class="rounded-3xl border-2 p-12 space-y-8 shadow-xl mt-8" style="background-color: white; border-color: rgba(139, 111, 71, 0.15);">
      <h2 class="text-lg font-semibold" style="color: #3D2E1F;">Your Specialties</h2>
      <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Help pet owners find you by sharing what types of dogs you work best with.</p>
      
      <!-- Dog Sizes -->
      <div class="space-y-3">
        <label class="text-sm" style="color: rgba(61, 46, 31, 0.7);">Dog sizes you work with</label>
        <div class="flex flex-wrap gap-3">
          <% %w[small medium large giant].each do |size| %>
            <label class="flex items-center gap-2 px-4 py-2 border-2 rounded-xl cursor-pointer hover:border-amber-600 transition-all" style="border-color: rgba(139, 111, 71, 0.2);">
              <%= check_box_tag "pro_profile[dog_sizes][]", size, @pro_profile.dog_sizes.to_s.include?(size), class: "rounded" %>
              <span class="text-sm" style="color: #3D2E1F;"><%= size.titleize %></span>
            </label>
          <% end %>
        </div>
      </div>
      
      <!-- Temperaments -->
      <div class="space-y-3">
        <label class="text-sm" style="color: rgba(61, 46, 31, 0.7);">Temperaments you're comfortable with</label>
        <div class="flex flex-wrap gap-3">
          <% %w[calm anxious energetic nervous reactive].each do |temp| %>
            <label class="flex items-center gap-2 px-4 py-2 border-2 rounded-xl cursor-pointer hover:border-amber-600 transition-all" style="border-color: rgba(139, 111, 71, 0.2);">
              <%= check_box_tag "pro_profile[temperaments][]", temp, @pro_profile.temperaments.to_s.include?(temp), class: "rounded" %>
              <span class="text-sm" style="color: #3D2E1F;"><%= temp.titleize %></span>
            </label>
          <% end %>
        </div>
      </div>
      
      <!-- Special Capabilities -->
      <div class="space-y-3">
        <label class="text-sm" style="color: rgba(61, 46, 31, 0.7);">I can work with</label>
        <div class="flex flex-wrap gap-3">
          <label class="flex items-center gap-2 px-4 py-2 border-2 rounded-xl cursor-pointer hover:border-amber-600 transition-all" style="border-color: rgba(139, 111, 71, 0.2);">
            <%= f.check_box :accepts_puppies, class: "rounded" %>
            <span class="text-sm" style="color: #3D2E1F;">Puppies (under 1 year)</span>
          </label>
          <label class="flex items-center gap-2 px-4 py-2 border-2 rounded-xl cursor-pointer hover:border-amber-600 transition-all" style="border-color: rgba(139, 111, 71, 0.2);">
            <%= f.check_box :accepts_senior_dogs, class: "rounded" %>
            <span class="text-sm" style="color: #3D2E1F;">Senior dogs (8+ years)</span>
          </label>
          <label class="flex items-center gap-2 px-4 py-2 border-2 rounded-xl cursor-pointer hover:border-amber-600 transition-all" style="border-color: rgba(139, 111, 71, 0.2);">
            <%= f.check_box :accepts_special_needs, class: "rounded" %>
            <span class="text-sm" style="color: #3D2E1F;">Special needs dogs</span>
          </label>
        </div>
      </div>
      
      <!-- Breed Experience -->
      <div class="space-y-3">
        <%= f.label :breed_specialties, "Breed specialties (optional)", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
        <%= f.text_area :breed_specialties, rows: 2, placeholder: "e.g., Golden Retrievers, Poodles, Bulldogs, Double-coated breeds...", class: "w-full px-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 resize-none transition-all shadow-sm hover:shadow-md", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.2);" %>
      </div>
      
      <!-- Home Environment -->
      <h3 class="text-base font-semibold pt-4" style="color: #3D2E1F;">Your Home Environment</h3>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-3">
          <%= f.label :home_type, "Home type", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
          <%= f.select :home_type, [["Select...", ""], ["Apartment", "apartment"], ["House", "house"], ["Studio", "studio"], ["Other", "other"]], {}, class: "w-full px-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 transition-all shadow-sm", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
        
        <div class="space-y-3">
          <%= f.label :other_pets, "Other pets in home", class: "text-sm", style: "color: rgba(61, 46, 31, 0.7);" %>
          <%= f.select :other_pets, [["Select...", ""], ["None", "none"], ["Dogs", "dogs"], ["Cats", "cats"], ["Dogs and cats", "dogs and cats"], ["Other", "other"]], {}, class: "w-full px-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 transition-all shadow-sm", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
      </div>
      
      <div class="flex flex-wrap gap-6">
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.check_box :has_garden, class: "rounded" %>
          <span class="text-sm" style="color: #3D2E1F;">Has garden/outdoor space</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.check_box :smoking_home, class: "rounded" %>
          <span class="text-sm" style="color: #3D2E1F;">Smoking household</span>
        </label>
      </div>
    </div>

    <div class="flex justify-between gap-4 pt-10">
      <%= link_to "Back", pros_setup_path(step: 1), class: "px-10 py-4 border-2 rounded-2xl hover:shadow-md transition-all", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
      <%= f.submit "Continue to Services", class: "px-10 py-4 text-white rounded-2xl hover:shadow-lg hover:scale-105 transition-all duration-300 cursor-pointer", style: "background-color: #8B6F47;" %>
    </div>
  <% end %>
</div>
