<div class="space-y-10">
  <div class="text-center max-w-xl mx-auto">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background-color: rgba(139, 111, 71, 0.1);">
      <svg class="w-4 h-4" fill="none" stroke="#8B6F47" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
      <span class="text-sm" style="color: #8B6F47;">Quick Start</span>
    </div>
    <h1 class="mb-4" style="font-family: Georgia, serif; font-size: 2rem; color: #3D2E1F;">Welcome to woof.day</h1>
    <p class="text-lg leading-relaxed" style="color: rgba(61, 46, 31, 0.6);">
      Let's set up your professional profile. Connect your Instagram to get started quickly, or skip to enter details manually.
    </p>
  </div>

  <div class="rounded-3xl border-2 overflow-hidden shadow-xl" style="background-color: white; border-color: rgba(139, 111, 71, 0.15);">
    <div class="p-14 text-center space-y-8" style="background: linear-gradient(to bottom right, white, rgba(249, 246, 241, 0.3));">
      <div class="w-24 h-24 mx-auto rounded-2xl flex items-center justify-center shadow-lg" style="background: linear-gradient(to bottom right, #E1306C, #C13584, #833AB4);">
        <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </div>
      <div>
        <h3 class="mb-3" style="font-size: 1.25rem; color: #3D2E1F;">Connect Your Instagram</h3>
        <p class="max-w-md mx-auto leading-relaxed" style="color: rgba(61, 46, 31, 0.6);">
          Import your photos, bio, and contact details instantly to create a stunning profile in seconds.
        </p>
      </div>
      <button type="button" class="px-10 py-4 text-white rounded-2xl hover:shadow-xl transition-all duration-300 hover:scale-105 inline-flex items-center gap-3" style="background: linear-gradient(to right, #E1306C, #C13584);">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"/>
        </svg>
        <span>Connect Instagram</span>
      </button>
    </div>

    <div class="relative px-14 py-6">
      <div class="absolute inset-x-14 top-1/2 -translate-y-1/2 flex items-center">
        <div class="w-full border-t" style="border-color: rgba(139, 111, 71, 0.15);"></div>
      </div>
      <div class="relative flex justify-center">
        <span class="px-5 text-sm" style="background-color: white; color: rgba(61, 46, 31, 0.4);">or continue without Instagram</span>
      </div>
    </div>

    <%= form_with url: pros_setup_path, method: :patch, class: "px-14 pb-14" do |f| %>
      <div class="space-y-3">
        <label class="text-sm flex items-center gap-2" style="color: rgba(61, 46, 31, 0.7);">
          Instagram Handle <span style="color: rgba(61, 46, 31, 0.4);">(Optional)</span>
        </label>
        <div class="relative group">
          <span class="absolute left-5 top-1/2 -translate-y-1/2" style="color: rgba(61, 46, 31, 0.4);">@</span>
          <%= f.text_field :instagram, value: @pro_profile.instagram, placeholder: "yourbusiness", class: "w-full pl-12 pr-5 py-4 border-2 rounded-2xl focus:outline-none focus:ring-2 transition-all shadow-sm", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.2);" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex justify-center pt-6">
    <%= button_to "Continue to Profile", pros_setup_path, method: :patch, class: "px-10 py-4 text-white rounded-2xl hover:shadow-lg hover:scale-105 transition-all duration-300 cursor-pointer", style: "background-color: #8B6F47;" %>
  </div>
</div>
