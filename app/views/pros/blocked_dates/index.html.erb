<div class="max-w-4xl mx-auto px-6 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-serif mb-2" style="font-weight: 700; color: #3D2E1F;">Blocked Dates</h1>
    <p style="color: rgba(61, 46, 31, 0.6);">Block dates when you're unavailable (holidays, vacation, etc.)</p>
  </div>

  <!-- Add Blocked Date Form -->
  <div class="border-2 rounded-2xl p-6 mb-8" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
    <h2 class="text-lg font-semibold mb-4" style="color: #3D2E1F;">Block a Date</h2>
    <%= form_with model: @blocked_date, url: pros_blocked_dates_path, class: "grid md:grid-cols-3 gap-4 items-end" do |f| %>
      <div>
        <%= f.label :date, "Date", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
        <%= f.date_field :date, min: Date.current, class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
      </div>
      <div>
        <%= f.label :reason, "Reason (optional)", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
        <%= f.text_field :reason, placeholder: "Holiday, vacation, etc.", class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2", style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
      </div>
      <div>
        <%= f.submit "Block Date", class: "w-full h-12 rounded-xl font-semibold cursor-pointer", style: "background-color: #8B6F47; color: #FAF7F2;" %>
      </div>
    <% end %>
  </div>

  <!-- Blocked Dates List -->
  <% if @blocked_dates.any? %>
    <div class="border-2 rounded-2xl overflow-hidden" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
      <% @blocked_dates.each do |bd| %>
        <div class="flex items-center justify-between border-b last:border-b-0 p-4" style="border-color: rgba(139, 111, 71, 0.1);">
          <div>
            <p class="font-semibold" style="color: #3D2E1F;"><%= bd.date.strftime("%A, %B %d, %Y") %></p>
            <% if bd.reason.present? %>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= bd.reason %></p>
            <% end %>
          </div>
          <%= button_to pros_blocked_date_path(bd), method: :delete, class: "px-4 py-2 rounded-lg text-sm font-semibold", style: "background-color: rgba(239, 68, 68, 0.1); color: rgb(220, 38, 38);" do %>
            Unblock
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 border-2 border-dashed rounded-2xl" style="border-color: rgba(139, 111, 71, 0.3);">
      <svg class="w-12 h-12 mx-auto mb-4" fill="none" stroke="rgba(139, 111, 71, 0.4)" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-lg mb-2" style="color: rgba(61, 46, 31, 0.6);">No blocked dates</p>
      <p class="text-sm" style="color: rgba(61, 46, 31, 0.4);">Your full schedule is available for bookings</p>
    </div>
  <% end %>

  <!-- Back Links -->
  <div class="mt-8 pt-8 border-t flex justify-between" style="border-color: rgba(139, 111, 71, 0.15);">
    <%= link_to "← Back to Availability", pros_availabilities_path, style: "color: #8B6F47;" %>
    <%= link_to "Back to Dashboard →", dashboard_path, style: "color: #8B6F47;" %>
  </div>
</div>
