<div class="mx-auto px-4 py-8 sm:px-6 lg:px-8" style="max-width: 1100px; width: 100%; overflow-x: hidden;">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-extrabold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">My Dashboard</h1>
      <p class="mt-1 font-medium" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Welcome back, <%= @user.display_name %>!</p>
    </div>
    <%= button_to "Log Out", session_path, method: :delete, class: "px-5 py-2.5 text-sm font-semibold rounded-xl transition-all duration-200 hover:translate-y-[-1px]", style: "background: linear-gradient(135deg, rgba(139, 111, 71, 0.08), rgba(139, 111, 71, 0.04)); color: #8B6F47; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.1); font-family: 'Nunito', sans-serif;" %>
  </div>

  <!-- Tabs Navigation -->
  <div class="flex flex-wrap gap-1.5 mb-6 p-1.5 rounded-2xl" style="background-color: rgba(139, 111, 71, 0.06); box-shadow: inset 0 1px 2px rgba(139, 111, 71, 0.08);">
    <button onclick="showTab('upcoming')" id="tab-upcoming" class="tab-btn flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold transition-all duration-200" style="background: linear-gradient(135deg, white, rgba(255,255,255,0.9)); color: #3D2E1F; box-shadow: 0 2px 8px rgba(139, 111, 71, 0.12); font-family: 'Nunito', sans-serif;">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Upcoming
    </button>
    <button onclick="showTab('past')" id="tab-past" class="tab-btn flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 hover:bg-white/50" style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
      </svg>
      Past
    </button>
    <button onclick="showTab('pets')" id="tab-pets" class="tab-btn flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 hover:bg-white/50" style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75A2.25 2.25 0 0116.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H13.48a4.53 4.53 0 01-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23H5.904M14.25 9h2.25M5.904 18.75c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 01-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 10.203 4.167 9.75 5 9.75h1.053c.472 0 .745.556.5.96a8.958 8.958 0 00-1.302 4.665c0 1.194.232 2.333.654 3.375z"/>
      </svg>
      My Pets
    </button>
    <% if @user.pro? %>
      <button onclick="showTab('pro')" id="tab-pro" class="tab-btn flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 hover:bg-white/50" style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/>
        </svg>
        Pro Dashboard
      </button>
    <% end %>
  </div>

  <!-- Tab Content: Upcoming -->
  <div id="content-upcoming" class="tab-content">
    <div class="rounded-xl border overflow-hidden" style="border-color: hsl(35, 20%, 88%); background-color: white;">
      <div class="px-6 py-4 border-b flex items-center justify-between" style="border-color: hsl(35, 20%, 88%);">
        <h2 class="text-lg font-semibold" style="color: hsl(20, 14%, 16%);">Upcoming Bookings</h2>
      </div>
      <div class="divide-y" style="border-color: hsl(35, 20%, 88%);">
        <% if @upcoming_bookings.empty? %>
          <div class="p-8 text-center">
            <div class="text-4xl mb-2">📅</div>
            <p style="color: hsl(25, 10%, 45%);">No upcoming bookings</p>
            <%= link_to "Find a Pro", search_path, class: "inline-block mt-3 font-medium", style: "color: #EC4899;" %>
          </div>
        <% else %>
          <% @upcoming_bookings.each do |booking| %>
            <div class="p-4 flex items-center gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background-color: rgba(236, 72, 153, 0.1);">
                🐕
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium truncate" style="color: hsl(20, 14%, 16%);"><%= booking.pet.name %> with <%= booking.pro_profile.business_name %></p>
                <p class="text-sm" style="color: hsl(25, 10%, 45%);"><%= booking.start_time.strftime("%b %d at %I:%M %p") %></p>
              </div>
              <span class="px-2.5 py-1 rounded-full text-xs font-medium" style="<%= booking.confirmed? ? 'background-color: rgba(16, 185, 129, 0.1); color: rgb(6, 95, 70);' : 'background-color: rgba(245, 158, 11, 0.1); color: rgb(146, 64, 14);' %>">
                <%= booking.status.titleize %>
              </span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tab Content: Past -->
  <div id="content-past" class="tab-content hidden">
    <div class="rounded-xl border overflow-hidden" style="border-color: hsl(35, 20%, 88%); background-color: white;">
      <div class="px-6 py-4 border-b" style="border-color: hsl(35, 20%, 88%);">
        <h2 class="text-lg font-semibold" style="color: hsl(20, 14%, 16%);">Past Bookings</h2>
      </div>
      <div class="divide-y" style="border-color: hsl(35, 20%, 88%);">
        <% if @past_bookings.empty? %>
          <div class="p-8 text-center">
            <p style="color: hsl(25, 10%, 45%);">No past bookings yet</p>
          </div>
        <% else %>
          <% @past_bookings.each do |booking| %>
            <div class="p-4 flex items-center gap-4">
              <div class="flex-1 min-w-0">
                <p class="font-medium" style="color: hsl(20, 14%, 16%);"><%= booking.pet.name %> with <%= booking.pro_profile.business_name %></p>
                <p class="text-sm" style="color: hsl(25, 10%, 45%);"><%= booking.start_time.strftime("%b %d, %Y") %></p>
              </div>
              <% if booking.completed? && booking.review.nil? %>
                <%= link_to "Leave Review", new_booking_review_path(booking), class: "text-sm font-medium", style: "color: #EC4899;" %>
              <% elsif booking.review.present? %>
                <span style="color: #F59E0B;"><%= booking.review.stars %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tab Content: My Pets -->
  <div id="content-pets" class="tab-content hidden">
    <div class="rounded-xl border overflow-hidden" style="border-color: hsl(35, 20%, 88%); background-color: white;">
      <div class="px-6 py-4 border-b flex items-center justify-between" style="border-color: hsl(35, 20%, 88%);">
        <h2 class="text-lg font-semibold" style="color: hsl(20, 14%, 16%);">My Pets</h2>
        <%= link_to new_pet_path, class: "flex items-center gap-1.5 text-sm font-medium", style: "color: #EC4899;" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add Pet
        <% end %>
      </div>
      <div class="divide-y" style="border-color: hsl(35, 20%, 88%);">
        <% if @pets.empty? %>
          <div class="p-8 text-center">
            <div class="text-4xl mb-2">🐾</div>
            <p class="mb-3" style="color: hsl(25, 10%, 45%);">Add your first pet</p>
            <%= link_to "Add Pet", new_pet_path, class: "inline-block rounded-xl px-4 py-2 text-sm font-bold text-white transition", style: "background-color: #EC4899;" %>
          </div>
        <% else %>
          <% @pets.each do |pet| %>
            <div class="p-4 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-xl" style="background-color: rgba(236, 72, 153, 0.1);">
                <%= pet.species == "dog" ? "🐕" : pet.species == "cat" ? "🐈" : "🐾" %>
              </div>
              <div class="flex-1">
                <p class="font-medium" style="color: hsl(20, 14%, 16%);"><%= pet.name %></p>
                <p class="text-sm" style="color: hsl(25, 10%, 45%);"><%= pet.breed.presence || pet.species.titleize %></p>
              </div>
              <%= link_to edit_pet_path(pet), style: "color: hsl(25, 10%, 45%);" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                </svg>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @user.pro? && @pro_profile %>
    <!-- Tab Content: Pro Dashboard -->
    <div id="content-pro" class="tab-content hidden">
      <!-- Stats Row -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Upcoming -->
        <div class="group rounded-2xl p-5 transition-all duration-200 hover:translate-y-[-2px]" style="background: linear-gradient(135deg, white, rgba(255,255,255,0.95)); box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 4px 12px rgba(139, 111, 71, 0.04);">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl transition-transform duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.15), rgba(139, 111, 71, 0.08)); box-shadow: 0 2px 6px rgba(139, 111, 71, 0.12);">
              <svg class="w-5 h-5" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
              </svg>
            </div>
            <span class="text-sm font-semibold" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Upcoming</span>
          </div>
          <p class="text-3xl font-extrabold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;"><%= @pro_bookings&.count || 0 %></p>
          <p class="text-xs mt-1 font-medium" style="color: #8B6F47; font-family: 'Nunito', sans-serif;">bookings</p>
        </div>
        
        <!-- Rating -->
        <div class="group rounded-2xl p-5 transition-all duration-200 hover:translate-y-[-2px]" style="background: linear-gradient(135deg, white, rgba(255,255,255,0.95)); box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 4px 12px rgba(139, 111, 71, 0.04);">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl transition-transform duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(198, 168, 118, 0.25), rgba(198, 168, 118, 0.12)); box-shadow: 0 2px 6px rgba(198, 168, 118, 0.15);">
              <svg class="w-5 h-5" fill="#C6A876" viewBox="0 0 24 24">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            </div>
            <span class="text-sm font-semibold" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Rating</span>
          </div>
          <p class="text-3xl font-extrabold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;"><%= @pro_profile.average_rating %></p>
          <p class="text-xs mt-1 font-medium" style="color: #C6A876; font-family: 'Nunito', sans-serif;"><%= @pro_profile.total_reviews %> reviews</p>
        </div>
        
        <!-- Services -->
        <div class="group rounded-2xl p-5 transition-all duration-200 hover:translate-y-[-2px]" style="background: linear-gradient(135deg, white, rgba(255,255,255,0.95)); box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 4px 12px rgba(139, 111, 71, 0.04);">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl transition-transform duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.15), rgba(139, 111, 71, 0.08)); box-shadow: 0 2px 6px rgba(139, 111, 71, 0.12);">
              <svg class="w-5 h-5" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/>
              </svg>
            </div>
            <span class="text-sm font-semibold" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Services</span>
          </div>
          <p class="text-3xl font-extrabold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;"><%= @pro_profile.services.count %></p>
          <p class="text-xs mt-1 font-medium" style="color: #8B6F47; font-family: 'Nunito', sans-serif;">active</p>
        </div>
        
        <!-- Plan -->
        <div class="group rounded-2xl p-5 transition-all duration-200 hover:translate-y-[-2px]" style="background: <%= @pro_profile.tier_pro? ? 'linear-gradient(135deg, rgba(139, 111, 71, 0.08), rgba(139, 111, 71, 0.03))' : 'linear-gradient(135deg, white, rgba(255,255,255,0.95))' %>; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 4px 12px rgba(139, 111, 71, 0.04);">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl transition-transform duration-200 group-hover:scale-105" style="background: <%= @pro_profile.tier_pro? ? 'linear-gradient(135deg, #8B6F47, #A68B5B)' : 'linear-gradient(135deg, rgba(61, 46, 31, 0.1), rgba(61, 46, 31, 0.05))' %>; box-shadow: <%= @pro_profile.tier_pro? ? '0 4px 12px rgba(139, 111, 71, 0.3)' : '0 2px 6px rgba(61, 46, 31, 0.08)' %>;">
              <svg class="w-5 h-5" fill="none" stroke="<%= @pro_profile.tier_pro? ? 'white' : 'rgba(61, 46, 31, 0.4)' %>" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
              </svg>
            </div>
            <span class="text-sm font-semibold" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Plan</span>
          </div>
          <p class="text-2xl font-extrabold" style="color: <%= @pro_profile.tier_pro? ? '#8B6F47' : '#3D2E1F' %>; font-family: 'Nunito', sans-serif;"><%= @pro_profile.tier_pro? ? 'Pro' : 'Free' %></p>
          <% if @pro_profile.tier_pro? %>
            <%= link_to "Manage →", pros_subscription_path, class: "text-xs font-bold mt-1 inline-block transition-colors hover:underline", style: "color: #8B6F47; font-family: 'Nunito', sans-serif;" %>
          <% else %>
            <%= link_to "Upgrade →", pros_subscription_path, class: "text-xs font-bold mt-1 inline-block transition-colors hover:underline", style: "color: #8B6F47; font-family: 'Nunito', sans-serif;" %>
          <% end %>
        </div>
      </div>

      <!-- Pro Dashboard Wrapper - Stimulus controller wraps both sections -->
      <div data-controller="pro-panel" data-pro-panel-profile-id-value="<%= @pro_profile.id %>">
      
      <!-- Manage Your Business Section -->
      <div class="rounded-2xl overflow-hidden mb-6" style="background-color: white; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 4px 12px rgba(139, 111, 71, 0.04); transition: box-shadow 0.2s ease;">
        <div class="px-6 py-4" style="border-bottom: 1px solid rgba(139, 111, 71, 0.06); background: linear-gradient(to right, rgba(139, 111, 71, 0.03), transparent);">
          <h2 class="text-lg font-bold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Manage Your Business</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
          <!-- Services -->
          <button data-action="click->pro-panel#select" data-pro-panel-section-param="services" class="pro-nav-btn group p-5 transition-all duration-200 flex flex-col items-center gap-3 text-center relative hover:bg-gradient-to-b hover:from-transparent hover:to-amber-50/50" style="border-right: 1px solid rgba(139, 111, 71, 0.06);">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl transition-all duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.12), rgba(139, 111, 71, 0.05)); box-shadow: 0 2px 8px rgba(139, 111, 71, 0.1);">
              <svg class="w-6 h-6" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            </div>
            <div>
              <p class="font-bold text-sm" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Services</p>
              <p class="text-xs mt-0.5 font-medium" style="color: #8B6F47; font-family: 'Nunito', sans-serif;"><%= @pro_profile.services.count %> active</p>
            </div>
          </button>
          
          <!-- Availability (default active) -->
          <button data-action="click->pro-panel#select" data-pro-panel-section-param="availability" class="pro-nav-btn group p-5 transition-all duration-200 flex flex-col items-center gap-3 text-center relative" style="border-right: 1px solid rgba(139, 111, 71, 0.06); background: linear-gradient(to bottom, rgba(139, 111, 71, 0.04), transparent);">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl transition-all duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, #8B6F47, #A68B5B); box-shadow: 0 4px 12px rgba(139, 111, 71, 0.25);">
              <svg class="w-6 h-6" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="font-bold text-sm" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Availability</p>
              <p class="text-xs mt-0.5 font-medium" style="color: #8B6F47; font-family: 'Nunito', sans-serif;">Weekly hours</p>
            </div>
          </button>
          
          <!-- Blocked Dates -->
          <button data-action="click->pro-panel#select" data-pro-panel-section-param="blocked" class="pro-nav-btn group p-5 transition-all duration-200 flex flex-col items-center gap-3 text-center relative hover:bg-gradient-to-b hover:from-transparent hover:to-amber-50/50" style="border-right: 1px solid rgba(139, 111, 71, 0.06);">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl transition-all duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.12), rgba(139, 111, 71, 0.05)); box-shadow: 0 2px 8px rgba(139, 111, 71, 0.1);">
              <svg class="w-6 h-6" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z"/></svg>
            </div>
            <div>
              <p class="font-bold text-sm" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Blocked</p>
              <p class="text-xs mt-0.5 font-medium" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Days off</p>
            </div>
          </button>
          
          <!-- Portfolio -->
          <button data-action="click->pro-panel#select" data-pro-panel-section-param="portfolio" class="pro-nav-btn group p-5 transition-all duration-200 flex flex-col items-center gap-3 text-center relative hover:bg-gradient-to-b hover:from-transparent hover:to-amber-50/50" style="border-right: 1px solid rgba(139, 111, 71, 0.06);">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl transition-all duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.12), rgba(139, 111, 71, 0.05)); box-shadow: 0 2px 8px rgba(139, 111, 71, 0.1);">
              <svg class="w-6 h-6" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
            </div>
            <div>
              <p class="font-bold text-sm" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Portfolio</p>
              <p class="text-xs mt-0.5 font-medium" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Photos</p>
            </div>
          </button>
          
          <!-- Profile -->
          <button data-action="click->pro-panel#select" data-pro-panel-section-param="profile" class="pro-nav-btn group p-5 transition-all duration-200 flex flex-col items-center gap-3 text-center relative hover:bg-gradient-to-b hover:from-transparent hover:to-amber-50/50" style="border-right: 1px solid rgba(139, 111, 71, 0.06);">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl transition-all duration-200 group-hover:scale-105" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.12), rgba(139, 111, 71, 0.05)); box-shadow: 0 2px 8px rgba(139, 111, 71, 0.1);">
              <svg class="w-6 h-6" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
            </div>
            <div>
              <p class="font-bold text-sm" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Profile</p>
              <p class="text-xs mt-0.5 font-medium" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Your info</p>
            </div>
          </button>
          
          <!-- Billing -->
          <button data-action="click->pro-panel#select" data-pro-panel-section-param="subscription" class="pro-nav-btn group p-5 transition-all duration-200 flex flex-col items-center gap-3 text-center relative hover:bg-gradient-to-b hover:from-transparent hover:to-amber-50/50">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl transition-all duration-200 group-hover:scale-105" style="background: <%= @pro_profile.tier_pro? ? 'linear-gradient(135deg, rgba(139, 111, 71, 0.12), rgba(139, 111, 71, 0.05))' : 'linear-gradient(135deg, rgba(198, 168, 118, 0.2), rgba(198, 168, 118, 0.08))' %>; box-shadow: 0 2px 8px rgba(139, 111, 71, 0.1);">
              <svg class="w-6 h-6" fill="none" stroke="<%= @pro_profile.tier_pro? ? '#8B6F47' : '#C6A876' %>" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>
            </div>
            <div>
              <p class="font-bold text-sm" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Billing</p>
              <p class="text-xs mt-0.5 font-semibold" style="color: <%= @pro_profile.tier_pro? ? '#8B6F47' : '#C6A876' %>; font-family: 'Nunito', sans-serif;"><%= @pro_profile.tier_pro? ? 'Pro Plan' : 'Free' %></p>
            </div>
          </button>
        </div>
      </div>

      <!-- Bottom Section: Bookings (left) + Content Panel (right) -->
      <div class="grid gap-6" style="grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);">
        <!-- Upcoming Bookings (Left - 1fr) -->
        <div style="background: white; min-height: 400px; border: 1px solid #E8E0D5;">
          <div class="px-5 py-4" style="border-bottom: 1px solid #E8E0D5;">
            <h2 class="font-semibold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Upcoming Bookings</h2>
          </div>
          <div class="divide-y overflow-y-auto" style="border-color: #F5F2ED; max-height: 340px;">
            <% if @pro_bookings.blank? %>
              <div class="p-8 text-center">
                <p class="text-4xl mb-3">📅</p>
                <p class="font-semibold" style="color: #3D2E1F;">No upcoming bookings</p>
                <p class="text-sm mt-1" style="color: #A89F91;">When clients book with you, they'll appear here</p>
              </div>
            <% else %>
              <% @pro_bookings.each do |booking| %>
                <%= link_to booking_path(booking), class: "block p-4 flex items-center gap-3 transition-colors hover:bg-amber-50/30" do %>
                  <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center" style="background: #F5F2ED;">
                    🐕
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-sm truncate" style="color: #3D2E1F;"><%= booking.pet&.name || 'Pet' %></p>
                    <p class="text-xs" style="color: #A89F91;"><%= booking.start_time.strftime("%b %d at %I:%M %p") %></p>
                  </div>
                  <span class="px-2 py-1 text-xs font-semibold" style="<%= booking.confirmed? ? 'background: #E8F5E9; color: #2E7D32;' : 'background: #FFF8E1; color: #F57F17;' %>">
                    <%= booking.status.titleize %>
                  </span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Content Panel (Right - 2fr) -->
        <div style="background: white; min-height: 400px; border: 1px solid #E8E0D5; overflow: hidden; min-width: 0;">
          <%= turbo_frame_tag "pro_panel", src: pros_availabilities_path(inline: true), data: { pro_panel_target: "frame" } do %>
            <div class="p-8 text-center" style="min-height: 400px;">
              <div class="animate-pulse flex flex-col items-center">
                <div class="w-10 h-10 mb-3" style="background: #F5F2ED;"></div>
                <div class="h-4 w-32" style="background: #F5F2ED;"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      
      </div><!-- End Pro Dashboard Wrapper -->
    </div>
  <% end %>

  <% unless @user.pro? %>
    <div class="mt-6 rounded-2xl border p-6" style="border-color: rgba(139, 111, 71, 0.2); background-color: rgba(139, 111, 71, 0.05);">
      <div class="flex items-start gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl text-white" style="background-color: #8B6F47;">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-bold mb-1" style="color: #3D2E1F;">Become a Pet Care Pro</h3>
          <p class="text-sm mb-3" style="color: rgba(61, 46, 31, 0.6);">List your pet care services, manage bookings, and grow your business on woof.day.</p>
          <%= link_to pricing_path, class: "inline-flex items-center gap-1 text-sm font-bold", style: "color: #8B6F47;" do %>
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
function showTab(tabName) {
  // Hide all content
  document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
  // Show selected content
  document.getElementById('content-' + tabName).classList.remove('hidden');
  
  // Update tab buttons
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.style.backgroundColor = 'transparent';
    btn.style.color = 'hsl(25, 10%, 45%)';
  });
  document.getElementById('tab-' + tabName).style.backgroundColor = 'white';
  document.getElementById('tab-' + tabName).style.color = 'hsl(20, 14%, 16%)';
}
</script>
