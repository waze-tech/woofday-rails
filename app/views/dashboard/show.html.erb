<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold" style="color: hsl(20, 14%, 16%);">My Dashboard</h1>
      <p style="color: hsl(25, 10%, 45%);">Welcome back, <%= @user.display_name %>!</p>
    </div>
    <%= button_to "Log Out", session_path, method: :delete, class: "px-4 py-2 text-sm font-medium rounded-xl border transition-colors hover:bg-gray-50", style: "border-color: hsl(30, 15%, 85%); color: hsl(25, 10%, 45%);" %>
  </div>

  <!-- Tabs Navigation -->
  <div class="flex flex-wrap gap-1 mb-6 p-1 rounded-xl" style="background-color: hsl(35, 20%, 92%);">
    <button onclick="showTab('upcoming')" id="tab-upcoming" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition" style="background-color: white; color: hsl(20, 14%, 16%);">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Upcoming
    </button>
    <button onclick="showTab('past')" id="tab-past" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition" style="color: hsl(25, 10%, 45%);">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      Past
    </button>
    <button onclick="showTab('pets')" id="tab-pets" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition" style="color: hsl(25, 10%, 45%);">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
      </svg>
      My Pets
    </button>
    <% if @user.pro? %>
      <button onclick="showTab('pro')" id="tab-pro" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition" style="color: hsl(25, 10%, 45%);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Pro Dashboard
      </button>
    <% end %>
  </div>

  <!-- Tab Content: Upcoming -->
  <div id="content-upcoming" class="tab-content">
    <div class="rounded-xl border overflow-hidden" style="border-color: hsl(35, 20%, 88%); background-color: white;">
      <div class="px-6 py-4 border-b flex items-center justify-between" style="border-color: hsl(35, 20%, 88%);">
        <h2 class="text-lg font-semibold" style="color: hsl(20, 14%, 16%);">Upcoming Bookings</h2>
      </div>
      <div class="divide-y" style="border-color: hsl(35, 20%, 88%);">
        <% if @upcoming_bookings.empty? %>
          <div class="p-8 text-center">
            <div class="text-4xl mb-2">📅</div>
            <p style="color: hsl(25, 10%, 45%);">No upcoming bookings</p>
            <%= link_to "Find a Pro", search_path, class: "inline-block mt-3 font-medium", style: "color: #EC4899;" %>
          </div>
        <% else %>
          <% @upcoming_bookings.each do |booking| %>
            <div class="p-4 flex items-center gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background-color: rgba(236, 72, 153, 0.1);">
                🐕
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium truncate" style="color: hsl(20, 14%, 16%);"><%= booking.pet.name %> with <%= booking.pro_profile.business_name %></p>
                <p class="text-sm" style="color: hsl(25, 10%, 45%);"><%= booking.start_time.strftime("%b %d at %I:%M %p") %></p>
              </div>
              <span class="px-2.5 py-1 rounded-full text-xs font-medium" style="<%= booking.confirmed? ? 'background-color: rgba(16, 185, 129, 0.1); color: rgb(6, 95, 70);' : 'background-color: rgba(245, 158, 11, 0.1); color: rgb(146, 64, 14);' %>">
                <%= booking.status.titleize %>
              </span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tab Content: Past -->
  <div id="content-past" class="tab-content hidden">
    <div class="rounded-xl border overflow-hidden" style="border-color: hsl(35, 20%, 88%); background-color: white;">
      <div class="px-6 py-4 border-b" style="border-color: hsl(35, 20%, 88%);">
        <h2 class="text-lg font-semibold" style="color: hsl(20, 14%, 16%);">Past Bookings</h2>
      </div>
      <div class="divide-y" style="border-color: hsl(35, 20%, 88%);">
        <% if @past_bookings.empty? %>
          <div class="p-8 text-center">
            <p style="color: hsl(25, 10%, 45%);">No past bookings yet</p>
          </div>
        <% else %>
          <% @past_bookings.each do |booking| %>
            <div class="p-4 flex items-center gap-4">
              <div class="flex-1 min-w-0">
                <p class="font-medium" style="color: hsl(20, 14%, 16%);"><%= booking.pet.name %> with <%= booking.pro_profile.business_name %></p>
                <p class="text-sm" style="color: hsl(25, 10%, 45%);"><%= booking.start_time.strftime("%b %d, %Y") %></p>
              </div>
              <% if booking.completed? && booking.review.nil? %>
                <%= link_to "Leave Review", new_booking_review_path(booking), class: "text-sm font-medium", style: "color: #EC4899;" %>
              <% elsif booking.review.present? %>
                <span style="color: #F59E0B;"><%= booking.review.stars %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tab Content: My Pets -->
  <div id="content-pets" class="tab-content hidden">
    <div class="rounded-xl border overflow-hidden" style="border-color: hsl(35, 20%, 88%); background-color: white;">
      <div class="px-6 py-4 border-b flex items-center justify-between" style="border-color: hsl(35, 20%, 88%);">
        <h2 class="text-lg font-semibold" style="color: hsl(20, 14%, 16%);">My Pets</h2>
        <%= link_to new_pet_path, class: "flex items-center gap-1.5 text-sm font-medium", style: "color: #EC4899;" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add Pet
        <% end %>
      </div>
      <div class="divide-y" style="border-color: hsl(35, 20%, 88%);">
        <% if @pets.empty? %>
          <div class="p-8 text-center">
            <div class="text-4xl mb-2">🐾</div>
            <p class="mb-3" style="color: hsl(25, 10%, 45%);">Add your first pet</p>
            <%= link_to "Add Pet", new_pet_path, class: "inline-block rounded-xl px-4 py-2 text-sm font-bold text-white transition", style: "background-color: #EC4899;" %>
          </div>
        <% else %>
          <% @pets.each do |pet| %>
            <div class="p-4 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-xl" style="background-color: rgba(236, 72, 153, 0.1);">
                <%= pet.species == "dog" ? "🐕" : pet.species == "cat" ? "🐈" : "🐾" %>
              </div>
              <div class="flex-1">
                <p class="font-medium" style="color: hsl(20, 14%, 16%);"><%= pet.name %></p>
                <p class="text-sm" style="color: hsl(25, 10%, 45%);"><%= pet.breed.presence || pet.species.titleize %></p>
              </div>
              <%= link_to edit_pet_path(pet), style: "color: hsl(25, 10%, 45%);" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                </svg>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @user.pro? && @pro_profile %>
    <!-- Tab Content: Pro Dashboard -->
    <div id="content-pro" class="tab-content hidden">
      <!-- Stats Row -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="rounded-2xl border p-5" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <span class="text-sm font-medium" style="color: rgba(61, 46, 31, 0.6);">Upcoming</span>
          </div>
          <p class="text-3xl font-bold" style="color: #3D2E1F;"><%= @pro_bookings&.count || 0 %></p>
        </div>
        <div class="rounded-2xl border p-5" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl" style="background-color: rgba(198, 168, 118, 0.2); color: #C6A876;">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            </div>
            <span class="text-sm font-medium" style="color: rgba(61, 46, 31, 0.6);">Rating</span>
          </div>
          <p class="text-3xl font-bold" style="color: #3D2E1F;"><%= @pro_profile.average_rating %></p>
          <p class="text-xs mt-1" style="color: rgba(61, 46, 31, 0.5);"><%= @pro_profile.total_reviews %> reviews</p>
        </div>
        <div class="rounded-2xl border p-5" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <span class="text-sm font-medium" style="color: rgba(61, 46, 31, 0.6);">Services</span>
          </div>
          <p class="text-3xl font-bold" style="color: #3D2E1F;"><%= @pro_profile.services.count %></p>
        </div>
        <div class="rounded-2xl border p-5" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl" style="background-color: <%= @pro_profile.tier_pro? ? 'rgba(139, 111, 71, 0.1)' : 'rgba(61, 46, 31, 0.05)' %>; color: <%= @pro_profile.tier_pro? ? '#8B6F47' : 'rgba(61, 46, 31, 0.4)' %>;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <span class="text-sm font-medium" style="color: rgba(61, 46, 31, 0.6);">Plan</span>
          </div>
          <p class="text-xl font-bold" style="color: #3D2E1F;"><%= @pro_profile.tier_pro? ? 'Pro' : 'Free' %></p>
          <% unless @pro_profile.tier_pro? %>
            <%= link_to "Upgrade", pros_subscription_path, class: "text-xs font-medium", style: "color: #8B6F47;" %>
          <% end %>
        </div>
      </div>

      <!-- Manage Your Business Section -->
      <div class="rounded-2xl border overflow-hidden mb-6" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;">
        <div class="px-6 py-4 border-b" style="border-color: rgba(139, 111, 71, 0.1);">
          <h2 class="text-lg font-semibold" style="color: #3D2E1F;">Manage Your Business</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x" style="border-color: rgba(139, 111, 71, 0.1);">
          <!-- Edit Profile -->
          <%= link_to edit_pro_profile_path(@pro_profile), class: "p-5 hover:bg-gray-50 transition flex items-start gap-4" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1" style="color: #3D2E1F;">Edit Profile</h3>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Update your bio, location, and contact info</p>
            </div>
          <% end %>
          
          <!-- Services -->
          <%= link_to pros_setup_path, class: "p-5 hover:bg-gray-50 transition flex items-start gap-4" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1" style="color: #3D2E1F;">Services & Pricing</h3>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Manage your services and set your rates</p>
            </div>
          <% end %>
          
          <!-- Availability -->
          <%= link_to pros_availabilities_path, class: "p-5 hover:bg-gray-50 transition flex items-start gap-4" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1" style="color: #3D2E1F;">Availability</h3>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Set your weekly schedule and hours</p>
            </div>
          <% end %>
          
          <!-- Blocked Dates -->
          <%= link_to pros_blocked_dates_path, class: "p-5 hover:bg-gray-50 transition flex items-start gap-4" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1" style="color: #3D2E1F;">Blocked Dates</h3>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Mark days you're unavailable</p>
            </div>
          <% end %>
          
          <!-- Portfolio -->
          <%= link_to pros_portfolio_photos_path, class: "p-5 hover:bg-gray-50 transition flex items-start gap-4" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1" style="color: #3D2E1F;">Portfolio</h3>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Showcase your work with photos</p>
            </div>
          <% end %>
          
          <!-- Subscription -->
          <%= link_to pros_subscription_path, class: "p-5 hover:bg-gray-50 transition flex items-start gap-4" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1" style="color: #3D2E1F;">Subscription</h3>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= @pro_profile.tier_pro? ? 'Manage your Pro subscription' : 'Upgrade to Pro for more features' %></p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Upcoming Bookings -->
      <div class="rounded-2xl border overflow-hidden" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;">
        <div class="px-6 py-4 border-b flex items-center justify-between" style="border-color: rgba(139, 111, 71, 0.1);">
          <h2 class="text-lg font-semibold" style="color: #3D2E1F;">Upcoming Bookings</h2>
        </div>
        <div class="divide-y" style="border-color: rgba(139, 111, 71, 0.1);">
          <% if @pro_bookings.blank? %>
            <div class="p-8 text-center">
              <div class="text-4xl mb-2">📅</div>
              <p style="color: rgba(61, 46, 31, 0.6);">No upcoming bookings</p>
              <p class="text-sm mt-1" style="color: rgba(61, 46, 31, 0.4);">When clients book with you, they'll appear here</p>
            </div>
          <% else %>
            <% @pro_bookings.each do |booking| %>
              <div class="p-4 flex items-center gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background-color: rgba(139, 111, 71, 0.1);">
                  🐕
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium truncate" style="color: #3D2E1F;"><%= booking.pet&.name || 'Pet' %></p>
                  <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= booking.start_time.strftime("%b %d at %I:%M %p") %></p>
                </div>
                <span class="px-2.5 py-1 rounded-full text-xs font-medium" style="<%= booking.confirmed? ? 'background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;' : 'background-color: rgba(198, 168, 118, 0.2); color: #C6A876;' %>">
                  <%= booking.status.titleize %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% unless @user.pro? %>
    <div class="mt-6 rounded-2xl border p-6" style="border-color: rgba(139, 111, 71, 0.2); background-color: rgba(139, 111, 71, 0.05);">
      <div class="flex items-start gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl text-white" style="background-color: #8B6F47;">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-bold mb-1" style="color: #3D2E1F;">Become a Pet Care Pro</h3>
          <p class="text-sm mb-3" style="color: rgba(61, 46, 31, 0.6);">List your pet care services, manage bookings, and grow your business on woof.day.</p>
          <%= link_to pricing_path, class: "inline-flex items-center gap-1 text-sm font-bold", style: "color: #8B6F47;" do %>
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
function showTab(tabName) {
  // Hide all content
  document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
  // Show selected content
  document.getElementById('content-' + tabName).classList.remove('hidden');
  
  // Update tab buttons
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.style.backgroundColor = 'transparent';
    btn.style.color = 'hsl(25, 10%, 45%)';
  });
  document.getElementById('tab-' + tabName).style.backgroundColor = 'white';
  document.getElementById('tab-' + tabName).style.color = 'hsl(20, 14%, 16%)';
}
</script>
