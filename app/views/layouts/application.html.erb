<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>woof.day - Find Trusted Pet Care</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      body { font-family: 'Nunito', sans-serif; }
      h1, h2, h3, h4, h5, h6, .font-heading { font-family: 'Nunito', sans-serif; }
      .font-serif { font-family: 'Nunito', sans-serif; }
      input, select, textarea, button { font-family: 'Nunito', sans-serif; }
    </style>
  </head>
  <body class="min-h-full flex flex-col" style="background-color: #FAF7F2; color: #3D2E1F;">
    <!-- Header -->
    <header class="sticky top-0 z-50 backdrop-blur-md border-b" style="background-color: rgba(255, 255, 255, 0.95); border-color: rgba(139, 111, 71, 0.15);">
      <div class="max-w-7xl mx-auto px-6 py-3">
        <div class="flex items-center justify-between">
          <%= link_to root_path, class: "flex items-center gap-3" do %>
            <img src="/logo.png" alt="Woof.Day" class="h-16 w-auto">
            <span class="text-2xl" style="font-weight: 800; color: #3D2E1F; font-family: 'Nunito', sans-serif;">Woof.Day</span>
          <% end %>

          <nav class="hidden md:flex items-center gap-6">
            <%= link_to "Services", search_path, class: "font-semibold transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.7); font-family: 'Nunito', sans-serif;" %>
            <%= link_to "How it works", "#how-it-works", class: "font-semibold transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.7); font-family: 'Nunito', sans-serif;" %>
            <%= link_to "For Pros", pricing_path, class: "font-semibold transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.7); font-family: 'Nunito', sans-serif;" %>

            <% if authenticated? %>
              <%= link_to dashboard_path, class: "px-6 py-2.5 rounded-2xl shadow-sm transition-all font-bold hover:translate-y-[-1px]", style: "background: linear-gradient(135deg, #8B6F47, #A68B5B); color: #FAF7F2; font-family: 'Nunito', sans-serif; box-shadow: 0 2px 8px rgba(139, 111, 71, 0.25);" do %>
                Dashboard
              <% end %>
            <% else %>
              <%= link_to new_session_path, class: "px-6 py-2.5 rounded-2xl shadow-sm transition-all font-bold hover:translate-y-[-1px]", style: "background: linear-gradient(135deg, #8B6F47, #A68B5B); color: #FAF7F2; font-family: 'Nunito', sans-serif; box-shadow: 0 2px 8px rgba(139, 111, 71, 0.25);" do %>
                Log In
              <% end %>
            <% end %>
          </nav>
        </div>
      </div>
    </header>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="border-b px-4 py-3" style="background-color: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.2);">
        <div class="max-w-7xl mx-auto flex items-center gap-2" style="color: rgb(6, 95, 70);">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="border-b px-4 py-3" style="background-color: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2);">
        <div class="max-w-7xl mx-auto flex items-center gap-2" style="color: rgb(153, 27, 27);">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
          <%= alert %>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="py-12 px-6 border-t" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-4 gap-8 mb-8">
          <div class="md:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <img src="/logo.png" alt="Woof.Day" class="h-14 w-auto">
              <span class="text-2xl" style="font-weight: 800; color: #3D2E1F; font-family: 'Nunito', sans-serif;">Woof.Day</span>
            </div>
            <p style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;" class="mb-4">
              The trusted pet care network connecting pet owners with verified professionals.
            </p>
            <p class="text-sm font-medium" style="color: rgba(61, 46, 31, 0.5); font-family: 'Nunito', sans-serif;">Made with love for pets · © <%= Time.current.year %> woof.day</p>
          </div>

          <div>
            <h4 class="mb-4 font-bold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Services</h4>
            <div class="space-y-2">
              <%= link_to "Pet Grooming", search_path(service: "grooming"), class: "block font-medium transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;" %>
              <%= link_to "Dog Walking", search_path(service: "walking"), class: "block font-medium transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;" %>
              <%= link_to "Pet Sitting", search_path(service: "sitting"), class: "block font-medium transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;" %>
              <%= link_to "Training", search_path(service: "training"), class: "block font-medium transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;" %>
            </div>
          </div>

          <div>
            <h4 class="mb-4 font-bold" style="color: #3D2E1F; font-family: 'Nunito', sans-serif;">Company</h4>
            <div class="space-y-2">
              <a href="#" class="block font-medium transition-colors hover:text-amber-700" style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;">About Us</a>
              <%= link_to "Become a Pro", new_pro_profile_path, class: "block font-medium transition-colors hover:text-amber-700", style: "color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;" %>
              <a href="#" class="block font-medium transition-colors hover:text-amber-700" style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;">Terms</a>
              <a href="#" class="block font-medium transition-colors hover:text-amber-700" style="color: rgba(61, 46, 31, 0.6); font-family: 'Nunito', sans-serif;">Privacy</a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
