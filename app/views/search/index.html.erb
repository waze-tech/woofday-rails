<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2" style="color: hsl(20, 14%, 16%);">Find a Pro</h1>
    <p style="color: hsl(25, 10%, 45%);">Browse verified pet care professionals near you.</p>
  </div>

  <!-- Search Filters -->
  <%= form_with url: search_path, method: :get, class: "mb-8 flex flex-wrap gap-4" do |f| %>
    <div class="flex-1 min-w-[200px]">
      <%= f.text_field :location, 
          value: params[:location],
          placeholder: "Location...",
          class: "w-full rounded-xl border px-4 py-2.5 text-sm focus:outline-none focus:ring-2",
          style: "border-color: hsl(35, 20%, 88%); background-color: white;" %>
    </div>
    <div class="flex-1 min-w-[200px]">
      <%= f.select :service, 
          options_for_select([
            ["All Services", ""],
            ["Dog Walking", "walking"],
            ["Pet Sitting", "sitting"],
            ["Grooming", "grooming"],
            ["Training", "training"]
          ], params[:service]),
          {},
          class: "w-full rounded-xl border px-4 py-2.5 text-sm focus:outline-none focus:ring-2",
          style: "border-color: hsl(35, 20%, 88%); background-color: white;" %>
    </div>
    <%= f.submit "Search", class: "rounded-xl px-6 py-2.5 text-sm font-bold text-white transition cursor-pointer", style: "background-color: #EC4899;" %>
  <% end %>

  <% if @pros.empty? %>
    <div class="rounded-xl border p-12 text-center" style="border-color: hsl(35, 20%, 88%); background-color: white;">
      <svg class="mx-auto h-12 w-12 mb-3" style="color: rgba(25, 10%, 45%, 0.4);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <h3 class="text-lg font-semibold mb-1" style="color: hsl(20, 14%, 16%);">No pros available yet</h3>
      <p class="text-sm mb-4" style="color: hsl(25, 10%, 45%);">Pet care professionals will appear here once they join the platform.</p>
      <% if authenticated? %>
        <%= link_to "Become a Pro", new_pro_profile_path, class: "inline-block rounded-xl px-6 py-2.5 text-sm font-bold text-white transition", style: "background-color: #EC4899;" %>
      <% end %>
    </div>
  <% else %>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% @pros.each do |pro| %>
        <div class="rounded-xl border overflow-hidden flex flex-col hover:shadow-md transition-all" style="border-color: hsl(35, 20%, 88%); background-color: white;">
          <div class="p-5 flex-1">
            <div class="flex items-start gap-3 mb-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-full text-white font-semibold text-lg" style="background-color: #EC4899;">
                <%= pro.business_name[0].upcase %>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-lg truncate" style="color: hsl(20, 14%, 16%);"><%= pro.business_name %></h3>
                <% if pro.location.present? %>
                  <div class="flex items-center gap-1 text-sm" style="color: hsl(25, 10%, 45%);">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span><%= pro.location %></span>
                  </div>
                <% end %>
              </div>
            </div>

            <% if pro.average_rating > 0 %>
              <div class="flex items-center gap-1.5 mb-3">
                <svg class="w-4 h-4" style="color: #F59E0B;" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                </svg>
                <span class="text-sm font-medium" style="color: hsl(20, 14%, 16%);"><%= pro.average_rating %></span>
                <span class="text-sm" style="color: hsl(25, 10%, 45%);">(<%= pro.total_reviews %> reviews)</span>
              </div>
            <% end %>

            <% if pro.bio.present? %>
              <p class="text-sm mb-3 line-clamp-2" style="color: hsl(25, 10%, 45%);"><%= pro.bio %></p>
            <% end %>

            <div class="flex flex-wrap gap-1.5 mb-3">
              <% if pro.verified? %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium" style="background-color: rgba(16, 185, 129, 0.1); color: rgb(6, 95, 70);">✓ Verified</span>
              <% end %>
              <% pro.available_services.first(2).each do |service| %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium" style="background-color: hsl(35, 20%, 92%); color: hsl(25, 10%, 45%);"><%= service %></span>
              <% end %>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-lg font-bold" style="color: #EC4899;">$<%= pro.hourly_rate %>/hr</span>
            </div>
          </div>

          <div class="border-t p-4" style="border-color: hsl(35, 20%, 88%);">
            <%= link_to pro_profile_path(pro), class: "block w-full text-center rounded-xl px-4 py-2.5 text-sm font-bold text-white transition", style: "background-color: #EC4899;" do %>
              View Profile
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
