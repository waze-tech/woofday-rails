<div class="mx-auto max-w-7xl px-6 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-serif mb-2" style="font-weight: 700; color: #3D2E1F;">Find a Pro</h1>
    <p style="color: rgba(61, 46, 31, 0.6);">Browse verified pet care professionals near you.</p>
  </div>

  <!-- Search Filters -->
  <%= form_with url: search_path, method: :get, class: "mb-8" do |f| %>
    <div class="border-2 rounded-2xl p-6" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
      <div class="grid md:grid-cols-4 gap-4">
        <div>
          <%= f.label :location, "Location", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
          <%= f.text_field :location, 
              value: params[:location],
              placeholder: "Enter postcode or city",
              class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
        <div>
          <%= f.label :service_type, "Service", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
          <%= f.select :service_type, 
              options_for_select([
                ["All Services", ""],
                ["Grooming", "grooming"],
                ["Dog Walking", "walking"],
                ["Pet Sitting", "sitting"],
                ["Training", "training"]
              ], params[:service_type]),
              {},
              class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
        <div>
          <%= f.label :min_rating, "Min Rating", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
          <%= f.select :min_rating, 
              options_for_select([
                ["Any Rating", ""],
                ["4+ Stars", "4"],
                ["3+ Stars", "3"]
              ], params[:min_rating]),
              {},
              class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
        <div>
          <%= f.label :sort, "Sort By", class: "block text-sm font-medium mb-1", style: "color: #3D2E1F;" %>
          <%= f.select :sort, 
              options_for_select([
                ["Best Match", ""],
                ["Highest Rated", "rating"],
                ["Most Reviews", "reviews"],
                ["Newest", "newest"]
              ], params[:sort]),
              {},
              class: "w-full h-12 px-4 border-2 rounded-xl focus:outline-none focus:ring-2",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F;" %>
        </div>
      </div>
      <div class="flex items-center justify-between mt-4 pt-4 border-t" style="border-color: rgba(139, 111, 71, 0.1);">
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.check_box :available_this_week, { checked: params[:available_this_week] == "1" }, "1", "0" %>
          <span class="text-sm" style="color: #3D2E1F;">Available this week</span>
        </label>
        <%= f.submit "Search", class: "px-6 py-3 rounded-xl font-semibold cursor-pointer", style: "background-color: #8B6F47; color: #FAF7F2;" %>
      </div>
    </div>
  <% end %>

  <!-- Results -->
  <% if @pros.empty? %>
    <div class="rounded-2xl border-2 p-12 text-center" style="border-color: rgba(139, 111, 71, 0.15); background-color: #FFFFFF;">
      <svg class="mx-auto h-12 w-12 mb-3" fill="none" stroke="rgba(139, 111, 71, 0.4)" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <h3 class="text-lg font-semibold mb-1" style="color: #3D2E1F;">No pros found</h3>
      <p class="text-sm mb-4" style="color: rgba(61, 46, 31, 0.6);">Try adjusting your filters or search in a different area.</p>
      <% unless authenticated? %>
        <%= link_to "Become a Pro", pricing_path, class: "inline-block px-6 py-3 rounded-xl font-semibold", style: "background-color: #8B6F47; color: #FAF7F2;" %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm mb-4" style="color: rgba(61, 46, 31, 0.6);"><%= @pros.size %> pros found</p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% @pros.each do |pro| %>
        <div class="rounded-2xl border-2 overflow-hidden flex flex-col hover:shadow-lg transition-all" style="border-color: rgba(139, 111, 71, 0.15); background-color: #FFFFFF;">
          <div class="p-6 flex-1">
            <div class="flex items-start gap-4 mb-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl text-white font-semibold text-xl" style="background-color: #8B6F47;">
                <%= pro.business_name&.first&.upcase || "P" %>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="font-semibold text-lg truncate" style="color: #3D2E1F;"><%= pro.business_name %></h3>
                  <% if pro.is_verified %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs" style="background-color: rgba(16, 185, 129, 0.1); color: rgb(6, 95, 70);">✓</span>
                  <% end %>
                </div>
                <% if pro.location.present? %>
                  <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= pro.location %></p>
                <% end %>
              </div>
            </div>

            <% if pro.average_rating > 0 %>
              <div class="flex items-center gap-2 mb-3">
                <div class="flex">
                  <% 5.times do |i| %>
                    <svg class="w-4 h-4 <%= i < pro.average_rating.round ? '' : 'opacity-30' %>" fill="#F59E0B" viewBox="0 0 24 24">
                      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                    </svg>
                  <% end %>
                </div>
                <span class="text-sm font-medium" style="color: #3D2E1F;"><%= pro.average_rating %></span>
                <span class="text-sm" style="color: rgba(61, 46, 31, 0.5);">(<%= pro.total_reviews %>)</span>
              </div>
            <% end %>

            <% if pro.bio.present? %>
              <p class="text-sm mb-4 line-clamp-2" style="color: rgba(61, 46, 31, 0.7);"><%= pro.bio %></p>
            <% end %>

            <% if pro.services.any? %>
              <div class="flex flex-wrap gap-2">
                <% pro.services.limit(3).each do |service| %>
                  <span class="inline-block px-3 py-1 rounded-full text-xs" style="background-color: rgba(139, 111, 71, 0.1); color: #8B6F47;">
                    <%= service.name %> · €<%= service.price %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="border-t p-4" style="border-color: rgba(139, 111, 71, 0.1);">
            <% if pro.slug.present? %>
              <%= link_to pro_by_slug_path(slug: pro.slug), class: "block w-full text-center py-3 rounded-xl font-semibold transition-all hover:shadow-md", style: "background-color: #8B6F47; color: #FAF7F2;" do %>
                View Profile
              <% end %>
            <% else %>
              <%= link_to pro_profile_path(pro), class: "block w-full text-center py-3 rounded-xl font-semibold transition-all hover:shadow-md", style: "background-color: #8B6F47; color: #FAF7F2;" do %>
                View Profile
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
