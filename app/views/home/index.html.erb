<div class="flex flex-col">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 sm:py-28 lg:py-32" style="background: linear-gradient(135deg, hsl(40, 33%, 98%) 0%, hsl(40, 33%, 98%) 100%);">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 h-80 w-80 rounded-full blur-[120px]" style="background-color: rgba(236, 72, 153, 0.05);"></div>
      <div class="absolute -bottom-40 -left-40 h-80 w-80 rounded-full blur-[120px]" style="background-color: rgba(236, 72, 153, 0.05);"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-medium mb-6" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
          </svg>
          Trusted Pet Care Marketplace
        </div>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl" style="color: hsl(20, 14%, 16%);">
          Find trusted pet care
          <span class="block" style="color: #EC4899;">pros near you</span>
        </h1>
        <p class="mt-6 text-lg max-w-xl mx-auto leading-relaxed" style="color: hsl(25, 10%, 45%);">
          Whether you need dog walking, pet sitting, grooming, or training — woof.day connects you with verified, insured professionals who love pets as much as you do.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <%= link_to search_path, class: "inline-flex items-center gap-2 rounded-xl px-8 py-3.5 text-base font-bold text-white shadow-md hover:shadow-lg transition-all", style: "background-color: #EC4899; box-shadow: 0 4px 14px rgba(236, 72, 153, 0.2);" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            Find a Pro
          <% end %>
          <%= link_to new_pro_profile_path, class: "inline-flex items-center gap-2 rounded-xl border-2 px-8 py-3.5 text-base font-bold transition-all", style: "border-color: rgba(236, 72, 153, 0.2); background-color: white; color: #EC4899;" do %>
            List Your Business
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 border-y" style="background-color: white; border-color: hsl(35, 20%, 88%);">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold" style="color: hsl(20, 14%, 16%);">How It Works</h2>
        <p class="mt-3" style="color: hsl(25, 10%, 45%);">Getting started is easy — find the perfect pet pro in minutes</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <div class="relative text-center group">
          <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl transition-all duration-300 group-hover:text-white" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <div class="absolute -top-2 -right-2 flex h-7 w-7 items-center justify-center rounded-full text-white text-xs font-bold md:-top-1 md:-right-1" style="background-color: #EC4899;">
            1
          </div>
          <h3 class="text-lg font-bold mb-2" style="color: hsl(20, 14%, 16%);">Search & Compare</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(25, 10%, 45%);">Browse verified pet care professionals in your area. Filter by service, ratings, price, and availability.</p>
        </div>
        <div class="relative text-center group">
          <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl transition-all duration-300" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="absolute -top-2 -right-2 flex h-7 w-7 items-center justify-center rounded-full text-white text-xs font-bold md:-top-1 md:-right-1" style="background-color: #EC4899;">
            2
          </div>
          <h3 class="text-lg font-bold mb-2" style="color: hsl(20, 14%, 16%);">Book Online</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(25, 10%, 45%);">Choose a time that works for you. See real-time availability and book instantly with secure payments.</p>
        </div>
        <div class="relative text-center group">
          <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl transition-all duration-300" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>
          <div class="absolute -top-2 -right-2 flex h-7 w-7 items-center justify-center rounded-full text-white text-xs font-bold md:-top-1 md:-right-1" style="background-color: #EC4899;">
            3
          </div>
          <h3 class="text-lg font-bold mb-2" style="color: hsl(20, 14%, 16%);">Happy Pets</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(25, 10%, 45%);">Your pet gets amazing care from a trusted pro. Leave a review to help other pet owners.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold" style="color: hsl(20, 14%, 16%);">Why Choose woof.day?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="rounded-xl border p-6 hover:shadow-md transition-all duration-300" style="background-color: white; border-color: hsl(35, 20%, 88%);">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="font-bold mb-1.5" style="color: hsl(20, 14%, 16%);">Verified Pros</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(25, 10%, 45%);">Every professional is background-checked and insured for your peace of mind.</p>
        </div>
        <div class="rounded-xl border p-6 hover:shadow-md transition-all duration-300" style="background-color: white; border-color: hsl(35, 20%, 88%);">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
            </svg>
          </div>
          <h3 class="font-bold mb-1.5" style="color: hsl(20, 14%, 16%);">Real Reviews</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(25, 10%, 45%);">Read honest reviews from real pet owners to find the perfect match.</p>
        </div>
        <div class="rounded-xl border p-6 hover:shadow-md transition-all duration-300" style="background-color: white; border-color: hsl(35, 20%, 88%);">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-bold mb-1.5" style="color: hsl(20, 14%, 16%);">Easy Booking</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(25, 10%, 45%);">Book instantly online. Manage appointments, reschedule, or cancel with ease.</p>
        </div>
        <div class="rounded-xl border p-6 hover:shadow-md transition-all duration-300" style="background-color: white; border-color: hsl(35, 20%, 88%);">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg" style="background-color: rgba(236, 72, 153, 0.1); color: #EC4899;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          </div>
          <h3 class="font-bold mb-1.5" style="color: hsl(20, 14%, 16%);">All Pet Services</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(25, 10%, 45%);">Dog walking, pet sitting, grooming, training, and more — all in one place.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20" style="background: linear-gradient(135deg, #EC4899 0%, rgba(236, 72, 153, 0.9) 100%);">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to find the perfect pet care pro?</h2>
      <p class="mt-4 text-lg text-white/80">Join thousands of happy pet owners on woof.day</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <%= link_to search_path, class: "inline-flex items-center gap-2 rounded-xl px-8 py-3.5 text-base font-bold shadow-md hover:shadow-lg transition-all", style: "background-color: white; color: #EC4899;" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Find a Pro Near You
        <% end %>
      </div>
    </div>
  </section>
</div>
