<!-- Hero - Asymmetrical Grid -->
<section class="relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div class="relative z-10">
        <div class="inline-block mb-4">
          <div class="flex items-center gap-2 px-4 py-2 rounded-full" style="background-color: rgba(212, 196, 176, 0.4);">
            <svg class="w-4 h-4" fill="#8B6F47" viewBox="0 0 24 24">
              <path d="M12 3l1.5 4.5h4.5l-3.5 2.5 1.5 4.5-4-3-4 3 1.5-4.5-3.5-2.5h4.5z"/>
            </svg>
            <span class="text-sm" style="color: #3D2E1F;">Trusted by 50,000+ pet parents</span>
          </div>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl mb-6 font-serif leading-tight" style="font-weight: 700; color: #3D2E1F;">
          The best care for your
          <span class="relative inline-block">
            <span class="relative z-10">best friend</span>
            <div class="absolute -bottom-2 left-0 right-0 h-3 rounded-full" style="background-color: #C6A876; opacity: 0.4;"></div>
          </span>
        </h1>

        <p class="text-xl mb-8 leading-relaxed" style="color: rgba(61, 46, 31, 0.7);">
          Connect with verified pet stylists, groomers, and care professionals who love pets as much as you do
        </p>

        <!-- Search Box -->
        <div class="border-2 rounded-3xl p-3 shadow-lg max-w-lg" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
          <%= form_with url: search_path, method: :get, class: "flex items-center gap-3" do |f| %>
            <div class="flex-1 flex items-center gap-3 rounded-2xl px-4 py-3" style="background-color: #FAF7F2;">
              <svg class="w-5 h-5" fill="none" stroke="#6B5D4F" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              <%= f.text_field :location, placeholder: "Enter your postcode", class: "flex-1 bg-transparent border-none outline-none", style: "color: #3D2E1F;" %>
            </div>
            <%= f.submit "Search", class: "px-6 py-3 rounded-2xl shadow-sm transition-all cursor-pointer", style: "background-color: #8B6F47; color: #FAF7F2;" %>
          <% end %>
        </div>

        <!-- Trust Badges -->
        <div class="flex items-center gap-6 mt-8">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="#8B6F47" viewBox="0 0 24 24">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
            </svg>
            <span class="text-sm" style="color: rgba(61, 46, 31, 0.7);">4.9/5 Rating</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="#8B6F47" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <span class="text-sm" style="color: rgba(61, 46, 31, 0.7);">Verified Pros</span>
          </div>
        </div>
      </div>

      <!-- Right Visual -->
      <div class="relative hidden md:block">
        <div class="relative">
          <!-- Hero Dog Image with brown border -->
          <div class="hero-image-container rounded-[3rem] h-[500px] shadow-2xl p-8" style="background: linear-gradient(135deg, #D4C4B0, #A68B5B);">
            <div class="hero-image-inner">
              <img src="/hero-dog.jpg" alt="Happy dog" class="w-full h-full object-cover rounded-[3rem]">
            </div>
          </div>
          <style>
            .hero-image-inner {
              width: 100%;
              height: 100%;
              transform: rotate(2deg);
              transition: transform 0.4s ease-out;
              box-shadow: 0 20px 40px rgba(61, 46, 31, 0.3), 0 10px 20px rgba(61, 46, 31, 0.2);
              border-radius: 3rem;
              overflow: hidden;
            }
            .hero-image-container:hover .hero-image-inner {
              transform: rotate(-1deg) scale(1.02);
            }
          </style>

          <!-- Floating Card -->
          <div class="absolute -bottom-6 -left-6 border rounded-2xl p-6 shadow-xl max-w-xs" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
            <div class="flex items-start gap-3">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #E8DFD3;">
                <svg class="w-6 h-6" fill="#8B6F47" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold mb-1" style="color: #3D2E1F;">Booked in 30 seconds!</div>
                <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);">Join thousands of happy pet owners</p>
              </div>
            </div>
          </div>

          <!-- Decorative Element -->
          <div class="absolute -top-4 -right-4 w-24 h-24 rounded-full blur-2xl opacity-50" style="background-color: #D4C4B0;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Background Decorative Blob -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full blur-3xl opacity-20 -z-10" style="background-color: #E8DFD3;"></div>
</section>

<!-- Services Grid with Playful Cards -->
<section class="py-20 px-6" style="background-color: #FFFFFF;">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl mb-4 font-serif" style="font-weight: 700; color: #3D2E1F;">
        All the services your pet needs
      </h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: rgba(61, 46, 31, 0.6);">
        From grooming to training, find trusted professionals for every pet care need
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Pet Grooming -->
      <%= link_to search_path(service: "grooming"), class: "group block" do %>
        <div class="border-2 rounded-3xl p-8 transition-all hover:shadow-lg hover:-translate-y-1" style="background-color: #FAF7F2; border-color: rgba(139, 111, 71, 0.15);">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-4" style="background-color: #E8DFD3;">
            <img src="https://cdn-icons-png.freepik.com/512/2013/2013058.png" class="w-10 h-10" alt="Pet Grooming">
          </div>
          <h3 class="text-xl mb-2" style="font-weight: 600; color: #3D2E1F;">Pet Grooming</h3>
          <p class="mb-4" style="color: rgba(61, 46, 31, 0.6);">Professional styling & spa treatments</p>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="#8B6F47" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      <% end %>

      <!-- Dog Walking -->
      <%= link_to search_path(service: "walking"), class: "group block" do %>
        <div class="border-2 rounded-3xl p-8 transition-all hover:shadow-lg hover:-translate-y-1" style="background-color: #FAF7F2; border-color: rgba(139, 111, 71, 0.15);">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-4" style="background-color: #D4C4B0;">
            <img src="https://cdn-icons-png.freepik.com/512/6381/6381349.png" class="w-10 h-10" alt="Dog Walking">
          </div>
          <h3 class="text-xl mb-2" style="font-weight: 600; color: #3D2E1F;">Dog Walking</h3>
          <p class="mb-4" style="color: rgba(61, 46, 31, 0.6);">Daily walks & exercise routines</p>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="#8B6F47" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      <% end %>

      <!-- Pet Sitting -->
      <%= link_to search_path(service: "sitting"), class: "group block" do %>
        <div class="border-2 rounded-3xl p-8 transition-all hover:shadow-lg hover:-translate-y-1" style="background-color: #FAF7F2; border-color: rgba(139, 111, 71, 0.15);">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-4" style="background-color: #C6A876;">
            <img src="https://cdn-icons-png.freepik.com/512/5020/5020290.png" class="w-10 h-10" alt="Pet Sitting">
          </div>
          <h3 class="text-xl mb-2" style="font-weight: 600; color: #3D2E1F;">Pet Sitting</h3>
          <p class="mb-4" style="color: rgba(61, 46, 31, 0.6);">In-home care & overnight stays</p>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="#8B6F47" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      <% end %>

      <!-- Training -->
      <%= link_to search_path(service: "training"), class: "group block" do %>
        <div class="border-2 rounded-3xl p-8 transition-all hover:shadow-lg hover:-translate-y-1" style="background-color: #FAF7F2; border-color: rgba(139, 111, 71, 0.15);">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-4" style="background-color: #A68B5B;">
            <img src="https://cdn-icons-png.freepik.com/512/6381/6381356.png" class="w-10 h-10" alt="Training">
          </div>
          <h3 class="text-xl mb-2" style="font-weight: 600; color: #3D2E1F;">Training</h3>
          <p class="mb-4" style="color: rgba(61, 46, 31, 0.6);">Behavior & obedience classes</p>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="#8B6F47" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- How It Works - Step by Step -->
<section id="how-it-works" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl mb-4 font-serif" style="font-weight: 700; color: #3D2E1F;">
        Simple as 1, 2, 3
      </h2>
      <p class="text-lg" style="color: rgba(61, 46, 31, 0.6);">Getting started is easy and quick</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <% [
        { step: '1', title: 'Search & Browse', desc: 'Enter your location and browse verified pet care professionals near you', highlight: 'Find your perfect match' },
        { step: '2', title: 'Compare & Choose', desc: 'Read reviews, check availability, and compare prices to find the best fit', highlight: 'Real reviews, real results' },
        { step: '3', title: 'Book & Relax', desc: 'Schedule your appointment instantly and enjoy peace of mind', highlight: 'Done in 60 seconds' }
      ].each_with_index do |item, i| %>
        <div class="relative">
          <div class="border-2 rounded-3xl p-8 transition-all" style="background-color: #FFFFFF; border-color: rgba(139, 111, 71, 0.15);">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-6 font-serif" style="background-color: #8B6F47; color: #FAF7F2; font-weight: 700;">
              <%= item[:step] %>
            </div>
            <h3 class="text-2xl mb-3" style="font-weight: 600; color: #3D2E1F;"><%= item[:title] %></h3>
            <p class="mb-4 leading-relaxed" style="color: rgba(61, 46, 31, 0.7);"><%= item[:desc] %></p>
            <div class="inline-block px-4 py-2 rounded-full" style="background-color: rgba(212, 196, 176, 0.5);">
              <span class="text-sm" style="color: rgba(61, 46, 31, 0.8);"><%= item[:highlight] %></span>
            </div>
          </div>
          <% if i < 2 %>
            <svg class="hidden md:block absolute top-1/2 -right-4 w-6 h-6" fill="none" stroke="#6B5D4F" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Why Choose - Feature Highlights -->
<section class="py-20 px-6" style="background-color: #FFFFFF;">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-4xl md:text-5xl mb-6 font-serif" style="font-weight: 700; color: #3D2E1F;">
          Why pet owners love woof.day
        </h2>

        <div class="space-y-4">
          <% [
            { title: 'Verified & Trusted', desc: 'Every professional is background checked and certified' },
            { title: 'Transparent Pricing', desc: 'No hidden fees, see prices upfront before booking' },
            { title: 'Real Reviews', desc: 'Honest feedback from real pet owners in your area' },
            { title: 'Instant Booking', desc: 'Book appointments 24/7 with real-time availability' }
          ].each do |feature| %>
            <div class="flex gap-4 rounded-2xl p-6 border" style="background-color: #FAF7F2; border-color: rgba(139, 111, 71, 0.15);">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color: rgba(139, 111, 71, 0.1);">
                  <svg class="w-5 h-5" fill="#8B6F47" viewBox="0 0 24 24">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="mb-1" style="font-weight: 600; color: #3D2E1F;"><%= feature[:title] %></h3>
                <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= feature[:desc] %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="relative hidden md:block">
        <div class="rounded-[3rem] h-[500px] shadow-2xl" style="background: linear-gradient(135deg, #A68B5B, #8B6F47);"></div>
        <div class="absolute -bottom-8 -right-8 backdrop-blur-sm border rounded-2xl p-6 max-w-xs" style="background-color: rgba(212, 196, 176, 0.8); border-color: rgba(139, 111, 71, 0.15);">
          <div class="text-4xl mb-2 font-serif" style="font-weight: 700; color: #8B6F47;">4.9★</div>
          <p style="color: rgba(61, 46, 31, 0.7);">Average rating from 12,000+ reviews</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats Bar -->
<section class="py-12 px-6" style="background-color: #8B6F47; color: #FAF7F2;">
  <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
    <% [
      { num: '10,000+', label: 'Verified Pros' },
      { num: '50,000+', label: 'Happy Pets' },
      { num: '150,000+', label: 'Bookings' },
      { num: '4.9★', label: 'Avg Rating' }
    ].each do |stat| %>
      <div>
        <div class="text-3xl md:text-4xl mb-2 font-serif" style="font-weight: 700;"><%= stat[:num] %></div>
        <div class="text-sm opacity-90"><%= stat[:label] %></div>
      </div>
    <% end %>
  </div>
</section>

<!-- CTA -->
<section class="py-20 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="rounded-[3rem] p-12 md:p-16 text-center relative overflow-hidden" style="background: linear-gradient(135deg, #E8DFD3, #D4C4B0);">
      <div class="relative z-10">
        <h2 class="text-4xl md:text-5xl mb-6 font-serif" style="font-weight: 700; color: #3D2E1F;">
          Ready to find your perfect pet pro?
        </h2>
        <p class="text-xl mb-8 max-w-2xl mx-auto" style="color: rgba(61, 46, 31, 0.7);">
          Join thousands of pet owners who trust woof.day for all their pet care needs
        </p>
        <%= link_to search_path, class: "inline-flex items-center gap-2 px-10 py-4 rounded-2xl shadow-lg text-lg transition-all", style: "background-color: #8B6F47; color: #FAF7F2;" do %>
          Get Started Now
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
      <div class="absolute top-0 right-0 w-64 h-64 rounded-full blur-3xl opacity-20" style="background-color: #FFFFFF;"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full blur-3xl opacity-10" style="background-color: #8B6F47;"></div>
    </div>
  </div>
</section>
