<div class="mx-auto px-4 py-8 sm:px-6" style="max-width: 640px; font-family: 'Nunito', sans-serif;">
  
  <!-- Back Link -->
  <%= link_to dashboard_path, class: "inline-flex items-center gap-2 text-sm font-medium mb-6 transition-colors", style: "color: rgba(61, 46, 31, 0.5);" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
    Back
  <% end %>

  <!-- Pet Header Card -->
  <div class="rounded-2xl overflow-hidden mb-6" style="background: white; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 8px 24px rgba(139, 111, 71, 0.06);">
    
    <!-- Pet Photo -->
    <div class="relative h-48 sm:h-64 flex items-center justify-center" style="background: linear-gradient(135deg, #E8E0D5, #D4C8B8);">
      <% if @pet.photo_url.present? %>
        <%= image_tag @pet.photo_url, class: "w-full h-full object-cover" %>
      <% else %>
        <span class="text-8xl"><%= @pet.species_dog? ? '🐕' : (@pet.species_cat? ? '🐈' : '🐾') %></span>
      <% end %>
      
      <!-- Edit Button -->
      <%= link_to edit_pet_path(@pet), class: "absolute top-4 right-4 p-2 rounded-full transition-all", style: "background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" do %>
        <svg class="w-5 h-5" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125"/></svg>
      <% end %>
    </div>
    
    <!-- Pet Info -->
    <div class="p-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h1 class="text-2xl font-extrabold mb-1" style="color: #3D2E1F;"><%= @pet.name %></h1>
          <p class="text-sm" style="color: rgba(61, 46, 31, 0.6);"><%= @pet.breed.presence || @pet.species.humanize %></p>
        </div>
        <span class="px-3 py-1.5 rounded-full text-xs font-bold" style="background: rgba(139, 111, 71, 0.08); color: #8B6F47;">
          <%= @pet.species.humanize %>
        </span>
      </div>
      
      <!-- Quick Stats -->
      <div class="grid grid-cols-3 gap-4 py-4" style="border-top: 1px solid rgba(139, 111, 71, 0.08); border-bottom: 1px solid rgba(139, 111, 71, 0.08);">
        <div class="text-center">
          <p class="text-xl font-extrabold" style="color: #3D2E1F;"><%= @pet.age.presence || '—' %></p>
          <p class="text-xs" style="color: rgba(61, 46, 31, 0.5);">Age</p>
        </div>
        <div class="text-center">
          <p class="text-xl font-extrabold" style="color: #3D2E1F;"><%= @pet.size&.titleize || '—' %></p>
          <p class="text-xs" style="color: rgba(61, 46, 31, 0.5);">Size</p>
        </div>
        <div class="text-center">
          <p class="text-xl font-extrabold" style="color: #3D2E1F;"><%= @pet.bookings.completed.count %></p>
          <p class="text-xs" style="color: rgba(61, 46, 31, 0.5);">Bookings</p>
        </div>
      </div>
      
      <% if @pet.notes.present? %>
        <div class="mt-4">
          <h3 class="text-xs font-bold uppercase tracking-wide mb-2" style="color: rgba(61, 46, 31, 0.4);">Special Notes</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(61, 46, 31, 0.8);"><%= @pet.notes %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Booking History -->
  <div class="rounded-2xl overflow-hidden mb-6" style="background: white; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 8px 24px rgba(139, 111, 71, 0.06);">
    <div class="p-5 flex items-center justify-between" style="border-bottom: 1px solid rgba(139, 111, 71, 0.08);">
      <h2 class="font-bold" style="color: #3D2E1F;">Booking History</h2>
      <%= link_to "Find a Pro", search_path, class: "text-sm font-semibold", style: "color: #8B6F47;" %>
    </div>
    
    <% completed_bookings = @pet.bookings.completed.includes(:pro_profile).order(created_at: :desc).limit(5) %>
    <% if completed_bookings.any? %>
      <div class="divide-y" style="border-color: rgba(139, 111, 71, 0.06);">
        <% completed_bookings.each do |booking| %>
          <%= link_to booking_path(booking), class: "block p-4 transition-colors hover:bg-amber-50/30" do %>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, rgba(139, 111, 71, 0.1), rgba(139, 111, 71, 0.05));">
                <svg class="w-5 h-5" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold truncate" style="color: #3D2E1F;"><%= booking.pro_profile.business_name %></p>
                <p class="text-sm" style="color: rgba(61, 46, 31, 0.5);"><%= booking.start_time.strftime("%b %d, %Y") %></p>
              </div>
              <% if booking.review.present? %>
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="#F59E0B" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  <span class="text-sm font-semibold" style="color: #3D2E1F;"><%= booking.review.rating %></span>
                </div>
              <% else %>
                <span class="text-xs font-medium px-2 py-1 rounded-full" style="background: rgba(245, 158, 11, 0.1); color: rgb(217, 119, 6);">Leave review</span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="p-8 text-center">
        <span class="text-4xl mb-3 block">📅</span>
        <p class="font-semibold" style="color: #3D2E1F;">No bookings yet</p>
        <p class="text-sm mt-1 mb-4" style="color: rgba(61, 46, 31, 0.5);">Find a trusted pet carer for <%= @pet.name %></p>
        <%= link_to "Browse Pet Carers", search_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold transition-all", style: "background: #8B6F47; color: white;" %>
      </div>
    <% end %>
  </div>

  <!-- Reviews Given -->
  <% reviews_given = Review.where(booking: @pet.bookings).order(created_at: :desc).limit(3) %>
  <% if reviews_given.any? %>
    <div class="rounded-2xl overflow-hidden mb-6" style="background: white; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08), 0 8px 24px rgba(139, 111, 71, 0.06);">
      <div class="p-5" style="border-bottom: 1px solid rgba(139, 111, 71, 0.08);">
        <h2 class="font-bold" style="color: #3D2E1F;"><%= @pet.name %>'s Reviews</h2>
      </div>
      <div class="divide-y" style="border-color: rgba(139, 111, 71, 0.06);">
        <% reviews_given.each do |review| %>
          <div class="p-4">
            <div class="flex items-center gap-2 mb-2">
              <% review.rating.times do %>
                <svg class="w-4 h-4" fill="#F59E0B" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% end %>
              <span class="text-xs" style="color: rgba(61, 46, 31, 0.4);">for <%= review.booking.pro_profile.business_name %></span>
            </div>
            <% if review.content.present? %>
              <p class="text-sm" style="color: rgba(61, 46, 31, 0.8);"><%= review.content %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Quick Actions -->
  <div class="grid grid-cols-2 gap-3">
    <%= link_to edit_pet_path(@pet), class: "flex items-center justify-center gap-2 p-4 rounded-xl font-semibold text-sm transition-all", style: "background: white; color: #3D2E1F; box-shadow: 0 1px 3px rgba(139, 111, 71, 0.08);" do %>
      <svg class="w-5 h-5" fill="none" stroke="#8B6F47" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125"/></svg>
      Edit Profile
    <% end %>
    <%= link_to search_path, class: "flex items-center justify-center gap-2 p-4 rounded-xl font-semibold text-sm transition-all", style: "background: #8B6F47; color: white;" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
      Find a Carer
    <% end %>
  </div>

</div>
