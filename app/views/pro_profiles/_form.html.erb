<%= form_with model: pro_profile, url: pro_profile.persisted? ? pro_profile_path(pro_profile) : pro_profiles_path, class: "space-y-6" do |f| %>
  <% if pro_profile.errors.any? %>
    <div class="rounded-xl border p-4" style="background-color: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2);">
      <% pro_profile.errors.full_messages.each do |message| %>
        <p class="text-sm" style="color: rgb(153, 27, 27);"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="rounded-xl border p-6 space-y-6" style="background-color: white; border-color: hsl(35, 20%, 88%);">
    <div>
      <label class="block text-sm font-medium mb-1" style="color: hsl(25, 10%, 45%);">Business Name *</label>
      <%= f.text_field :business_name, 
          placeholder: "e.g., Happy Paws Pet Care",
          required: true,
          class: "w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2",
          style: "border-color: hsl(35, 20%, 88%);" %>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1" style="color: hsl(25, 10%, 45%);">Hourly Rate ($) *</label>
      <%= f.number_field :hourly_rate, 
          min: 1,
          step: 0.01,
          placeholder: "e.g., 25.00",
          required: true,
          class: "w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2",
          style: "border-color: hsl(35, 20%, 88%);" %>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1" style="color: hsl(25, 10%, 45%);">Location</label>
      <%= f.text_field :location, 
          placeholder: "e.g., San Francisco, CA",
          class: "w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2",
          style: "border-color: hsl(35, 20%, 88%);" %>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1" style="color: hsl(25, 10%, 45%);">Services (comma separated)</label>
      <%= f.text_field :services, 
          placeholder: "e.g., Dog Walking, Pet Sitting, Grooming",
          class: "w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2",
          style: "border-color: hsl(35, 20%, 88%);" %>
      <p class="text-xs mt-1" style="color: hsl(25, 10%, 45%);">Enter services separated by commas</p>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1" style="color: hsl(25, 10%, 45%);">About You</label>
      <%= f.text_area :bio, 
          rows: 4,
          placeholder: "Tell pet owners about yourself, your experience, and why they should trust you with their pets...",
          class: "w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2 resize-none",
          style: "border-color: hsl(35, 20%, 88%);" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit pro_profile.persisted? ? "Save Changes" : "Create Profile", 
        class: "rounded-xl px-6 py-3 text-base font-bold text-white shadow-md transition cursor-pointer",
        style: "background-color: #EC4899; box-shadow: 0 4px 14px rgba(236, 72, 153, 0.2);" %>
    <%= link_to "Cancel", dashboard_path, class: "font-medium", style: "color: hsl(25, 10%, 45%);" %>
  </div>
<% end %>
