<%= turbo_frame_tag "pro_panel" do %><div style="min-height: 360px;">
  <div class="px-5 py-4 border-b" style="border-color: rgba(139, 111, 71, 0.1);">
    <h2 class="text-lg font-semibold" style="color: #3D2E1F;">Edit Profile</h2>
  </div>
  
  <div class="p-5">
    <%= form_with model: @pro_profile, url: pro_profile_path(@pro_profile), class: "space-y-4" do |f| %>
      <div>
        <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Business Name</label>
        <%= f.text_field :business_name, class: "w-full px-3 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
      </div>
      
      <div>
        <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Bio</label>
        <%= f.text_area :bio, rows: 4, class: "w-full px-3 py-2 text-sm border rounded-lg resize-none", style: "border-color: rgba(139, 111, 71, 0.2);", placeholder: "Tell clients about yourself..." %>
      </div>
      
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Location</label>
          <%= f.text_field :location, class: "w-full px-3 py-2 text-sm border rounded-lg", style: "border-color: rgba(139, 111, 71, 0.2);", placeholder: "e.g., Dublin, Ireland" %>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1" style="color: #3D2E1F;">Hourly Rate</label>
          <div class="flex">
            <span class="px-3 py-2 text-sm border border-r-0 rounded-l-lg" style="border-color: rgba(139, 111, 71, 0.2); background-color: rgba(139, 111, 71, 0.05); color: rgba(61, 46, 31, 0.6);">€</span>
            <%= f.number_field :hourly_rate, step: "0.01", min: 0, class: "w-full px-3 py-2 text-sm border rounded-r-lg", style: "border-color: rgba(139, 111, 71, 0.2);" %>
          </div>
        </div>
      </div>
      
      <div class="flex justify-end pt-2">
        <%= f.submit "Save Changes", class: "px-4 py-2 text-sm rounded-lg cursor-pointer", style: "background-color: #8B6F47; color: white;" %>
      </div>
    <% end %>
  </div>
</div><% end %>
