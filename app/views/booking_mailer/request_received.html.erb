<h1>New Booking Request!</h1>

<p>Hi <%= @pro.business_name %>,</p>

<p><strong><%= @customer.display_name %></strong> wants to book an appointment with you.</p>

<div style="background-color: #f5f5f5; padding: 20px; border-radius: 8px; margin: 20px 0;">
  <p><strong>Service:</strong> <%= @service&.name || "Not specified" %></p>
  <p><strong>Pet:</strong> <%= @pet.display_name %></p>
  <p><strong>Date:</strong> <%= @booking.start_time&.strftime("%A, %B %d, %Y") %></p>
  <p><strong>Time:</strong> <%= @booking.start_time&.strftime("%H:%M") %> - <%= @booking.end_time&.strftime("%H:%M") %></p>
  <% if @booking.notes.present? %>
    <p><strong>Notes:</strong> <%= @booking.notes %></p>
  <% end %>
</div>

<p>
  <a href="<%= dashboard_url %>" style="background-color: #8B6F47; color: white; padding: 12px 24px; text-decoration: none; border-radius: 8px;">
    View & Respond
  </a>
</p>

<p>Please respond within 24 hours to keep your response rate high.</p>

<p>— The woof.day team</p>
