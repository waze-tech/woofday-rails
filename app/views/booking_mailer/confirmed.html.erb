<h1>Booking Confirmed! 🎉</h1>

<p>Hi <%= @customer.display_name %>,</p>

<p>Great news! <strong><%= @pro.business_name %></strong> has confirmed your booking.</p>

<div style="background-color: #f5f5f5; padding: 20px; border-radius: 8px; margin: 20px 0;">
  <p><strong>Date:</strong> <%= @booking.start_time&.strftime("%A, %B %d, %Y") %></p>
  <p><strong>Time:</strong> <%= @booking.start_time&.strftime("%H:%M") %> - <%= @booking.end_time&.strftime("%H:%M") %></p>
  <p><strong>Location:</strong> <%= @pro.location %></p>
  <% if @pro.phone.present? %>
    <p><strong>Contact:</strong> <%= @pro.phone %></p>
  <% end %>
</div>

<p>
  <a href="<%= booking_url(@booking) %>" style="background-color: #8B6F47; color: white; padding: 12px 24px; text-decoration: none; border-radius: 8px;">
    View Booking Details
  </a>
</p>

<p>See you soon!</p>

<p>— The woof.day team</p>
