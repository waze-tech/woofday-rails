<div class="min-h-screen flex items-center justify-center px-4 py-12" style="background-color: #FAF7F2;">
  <div class="w-full max-w-lg">
    <div class="text-center mb-10">
      <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl mb-4" style="background-color: #E8DFD3;">
        <img src="https://cdn-icons-png.freepik.com/512/2013/2013058.png" class="w-8 h-8" alt="Woof.Day">
      </div>
      <h1 class="text-2xl font-bold" style="color: #3D2E1F;">Welcome to woof.day!</h1>
      <p class="mt-2" style="color: rgba(61, 46, 31, 0.6);">How would you like to use woof.day?</p>
    </div>

    <%= form_with model: User.new, url: registrations_path, class: "space-y-6", data: { controller: "role-select" } do |form| %>
      <% if @user&.errors&.any? %>
        <div class="rounded-xl border-2 p-4" style="background-color: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2);">
          <% @user.errors.full_messages.each do |message| %>
            <p class="text-sm" style="color: rgb(153, 27, 27);"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <!-- Role Selection -->
      <div class="space-y-4">
        <label class="role-card block w-full rounded-2xl border-2 p-6 text-left cursor-pointer transition-all hover:shadow-md hover:-translate-y-0.5" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;" onclick="this.querySelector('input').checked = true; document.querySelectorAll('.role-card').forEach(c => { c.style.borderColor = 'rgba(139, 111, 71, 0.15)'; c.style.backgroundColor = 'white'; }); this.style.borderColor = '#8B6F47'; this.style.backgroundColor = 'rgba(139, 111, 71, 0.05)';">
          <%= form.radio_button :role, "pet_owner", class: "sr-only" %>
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl" style="background-color: #E8DFD3;">
              <img src="https://cdn-icons-png.freepik.com/512/5020/5020290.png" class="w-6 h-6" alt="Pet Owner">
            </div>
            <div>
              <h3 class="text-lg font-bold" style="color: #3D2E1F;">I'm a Pet Owner</h3>
              <p class="mt-1 text-sm" style="color: rgba(61, 46, 31, 0.6);">Find and book trusted pet care professionals in your area</p>
            </div>
          </div>
        </label>

        <label class="role-card block w-full rounded-2xl border-2 p-6 text-left cursor-pointer transition-all hover:shadow-md hover:-translate-y-0.5" style="border-color: rgba(139, 111, 71, 0.15); background-color: white;" onclick="this.querySelector('input').checked = true; document.querySelectorAll('.role-card').forEach(c => { c.style.borderColor = 'rgba(139, 111, 71, 0.15)'; c.style.backgroundColor = 'white'; }); this.style.borderColor = '#8B6F47'; this.style.backgroundColor = 'rgba(139, 111, 71, 0.05)';">
          <%= form.radio_button :role, "pro", class: "sr-only" %>
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl" style="background-color: #D4C4B0;">
              <img src="https://cdn-icons-png.freepik.com/512/6381/6381356.png" class="w-6 h-6" alt="Pet Care Pro">
            </div>
            <div>
              <h3 class="text-lg font-bold" style="color: #3D2E1F;">I'm a Pet Care Pro</h3>
              <p class="mt-1 text-sm" style="color: rgba(61, 46, 31, 0.6);">List your services, manage bookings, and grow your business</p>
            </div>
          </div>
        </label>
      </div>

      <!-- Account Details -->
      <div class="rounded-2xl border-2 p-6 space-y-5" style="background-color: white; border-color: rgba(139, 111, 71, 0.15);">
        <div>
          <label class="block text-sm font-medium mb-2" style="color: #3D2E1F;">Email</label>
          <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "you@example.com",
              class: "w-full rounded-xl border-2 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-offset-0",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2" style="color: #3D2E1F;">Password</label>
          <%= form.password_field :password, required: true, autocomplete: "new-password",
              class: "w-full rounded-xl border-2 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-offset-0",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2" style="color: #3D2E1F;">Confirm Password</label>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
              class: "w-full rounded-xl border-2 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-offset-0",
              style: "border-color: rgba(139, 111, 71, 0.2); color: #3D2E1F; --tw-ring-color: rgba(139, 111, 71, 0.3);" %>
        </div>
      </div>

      <div>
        <%= form.submit "Continue", class: "w-full inline-flex items-center justify-center gap-2 rounded-xl px-8 py-3.5 text-base font-bold text-white shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all cursor-pointer", style: "background-color: #8B6F47;" %>
      </div>
    <% end %>

    <p class="text-center text-sm" style="color: rgba(61, 46, 31, 0.6);">
      Already have an account?
      <%= link_to "Sign in", new_session_path, class: "font-semibold hover:underline", style: "color: #8B6F47;" %>
    </p>
  </div>
</div>
